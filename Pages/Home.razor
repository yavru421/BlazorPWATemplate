                </span>
                <CapabilityBadge Supported="@_caps["camera"]" FeatureName="Camera" />
            </div>
            <h3 class="card-title">Camera & Video</h3>
            <p class="card-desc">Capture live video stream, switch between front/rear camera lenses, take photos, and download snapshots.</p>
        </div>

        <!-- Geolocation Card -->
        <div class="api-card" @onclick='() => NavigateTo("device/geo")'>
            <div class="card-glow geo-glow"></div>
            <div class="card-header">
                <span class="card-icon geo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </span>
                <CapabilityBadge Supported="@_caps["geo"]" FeatureName="Geolocation" />
            </div>
            <h3 class="card-title">Geolocation & Map</h3>
            <p class="card-desc">Track real-time latitude, longitude, and accuracy details mapped using an interactive Leaflet JS widget.</p>
        </div>

        <!-- Motion Card -->
        <div class="api-card" @onclick='() => NavigateTo("device/motion")'>
            <div class="card-glow motion-glow"></div>
            <div class="card-header">
                <span class="card-icon motion-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                </span>
                <CapabilityBadge Supported="@_caps["motion"]" FeatureName="Device Motion" />
            </div>
            <h3 class="card-title">Device Motion & Gyro</h3>
            <p class="card-desc">Read gyroscope, accelerometer, and device tilt coordinates dynamically represented by a 3D CSS wireframe phone.</p>
        </div>

        <!-- Haptics Card -->
        <div class="api-card" @onclick='() => NavigateTo("device/haptics")'>
            <div class="card-glow haptics-glow"></div>
            <div class="card-header">
                <span class="card-icon haptics-icon">
