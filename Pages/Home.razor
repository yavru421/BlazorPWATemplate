@page "/"
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Dashboard - GlassWASM PWA Template</PageTitle>

<div class="dashboard-container">
    <div class="hero-section">
        <h1 class="hero-title">WebAPI Glassmorphism</h1>
        <p class="hero-subtitle">A premium Blazor WebAssembly template demonstrating advanced HTML5 Web APIs and modern glassmorphic design systems.</p>
    </div>

    <h2 class="section-heading">Device & Hardware APIs</h2>
    <div class="card-grid">
        <!-- Camera Card -->
        <div class="api-card" @onclick='() => NavigateTo("device/camera")'>
            <div class="card-glow camera-glow"></div>
            <div class="card-header">
                <span class="card-icon camera-icon">
