            <div class="card-glow gestures-glow"></div>
            <div class="card-header">
                <span class="card-icon gestures-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v5m-4-1V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v7m8-3V8a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v3m-8-2h-.01M22 13a6 6 0 0 1-6 6H10a6 6 0 0 1-6-6V9a4 4 0 0 1 8 0v2"></path></svg>
