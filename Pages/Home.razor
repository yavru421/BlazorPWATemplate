            <div class="card-header">
                <span class="card-icon charts-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line><line x1="2" y1="20" x2="22" y2="20"></line></svg>
                </span>
            </div>
            <h3 class="card-title">Canvas Charts</h3>
            <p class="card-desc">Visualize custom metrics on canvas-drawn line graphs, bar charts, and donut segment configurations.</p>
        </div>

        <!-- Forms Card -->
        <div class="api-card ui" @onclick='() => NavigateTo("ui/forms")'>
            <div class="card-glow forms-glow"></div>
            <div class="card-header">
                <span class="card-icon forms-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </span>
            </div>
            <h3 class="card-title">Stunning Forms</h3>
            <p class="card-desc">Check out custom styled input widgets (color, sliders, selects) validated by full EditForm rules.</p>
        </div>

        <!-- Feedback Card -->
        <div class="api-card ui" @onclick='() => NavigateTo("ui/feedback")'>
            <div class="card-glow feedback-glow"></div>
            <div class="card-header">
                <span class="card-icon feedback-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                </span>
            </div>
            <h3 class="card-title">Feedback & Dialogs</h3>
            <p class="card-desc">Trigger modals, confirmation dialogs, toast notifications, and preview content-loading skeleton placeholders.</p>
        </div>
    </div>
</div>

@code {
    private Dictionary<string, bool> _caps = new()
    {
        { "camera", false },
        { "geo", false },
        { "motion", false },
        { "haptics", false },
        { "share", false },
        { "notify", false },
        { "battery", false },
        { "media", false },
        { "screen", false },
        { "bluetooth", false }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var results = await module.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                if (results != null)
                {
                    foreach (var key in results.Keys)
                    {
                        _caps[key] = results[key];
                    }
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("Failed to run capability scans: " + ex.Message);
            }
        }
    }

    private void NavigateTo(string path)
    {
        Navigation.NavigateTo(path);
    }
}
