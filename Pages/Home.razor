        </div>

        <!-- Screen Card -->
        <div class="api-card" @onclick='() => NavigateTo("device/screen")'>
            <div class="card-glow screen-glow"></div>
            <div class="card-header">
                <span class="card-icon screen-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                </span>
                <CapabilityBadge Supported="@_caps["screen"]" FeatureName="Screen Lock" />
            </div>
            <h3 class="card-title">Screen & Wake Lock</h3>
            <p class="card-desc">Control fullscreen modes, request screen orientation locks, and toggle Wake Lock to prevent displays dimming.</p>
        </div>

        <!-- Bluetooth Card -->
        <div class="api-card" @onclick='() => NavigateTo("device/bluetooth")'>
            <div class="card-glow bluetooth-glow"></div>
            <div class="card-header">
                <span class="card-icon bluetooth-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5l11 11L12 23V1l5.5 5.5-11 11"></path></svg>
                </span>
                <CapabilityBadge Supported="@_caps["bluetooth"]" FeatureName="Bluetooth/NFC" />
            </div>
            <h3 class="card-title">Bluetooth & NFC</h3>
            <p class="card-desc">Interact with surrounding BLE hardware nodes using Bluetooth scanning and read passive tags using WebNFC.</p>
        </div>
    </div>

    <h2 class="section-heading">UX & UI Design Patterns</h2>
    <div class="card-grid">
        <!-- Theme Card -->
        <div class="api-card ui" @onclick='() => NavigateTo("ui/theme")'>
            <div class="card-glow theme-glow"></div>
            <div class="card-header">
                <span class="card-icon theme-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="M12 18a6 6 0 1 0 0-12v12z"></path></svg>
                </span>
            </div>
            <h3 class="card-title">Live Themes</h3>
            <p class="card-desc">Switch settings (System/Dark/Light) and preview changes on interactive color palettes and custom variable tables.</p>
        </div>

        <!-- Transitions Card -->
