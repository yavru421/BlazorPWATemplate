                </span>
            </div>
            <h3 class="card-title">Transitions</h3>
            <p class="card-desc">Explore animations (Fades, Slides, Zoom, Scale, Flipping) for transitions on route contents and list containers.</p>
        </div>

        <!-- Surfaces Card -->
        <div class="api-card ui" @onclick='() => NavigateTo("ui/surfaces")'>
            <div class="card-glow surfaces-glow"></div>
            <div class="card-header">
                <span class="card-icon surfaces-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"></rect><rect x="14" y="3" width="7" height="5"></rect><rect x="14" y="12" width="7" height="9"></rect><rect x="3" y="16" width="7" height="5"></rect></svg>
                </span>
            </div>
