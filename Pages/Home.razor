            <h3 class="card-title">Notifications</h3>
            <p class="card-desc">Register system notification permissions, launch prompt alerts instantly, or delay alerts for background delivery.</p>
        </div>

        <!-- Battery Card -->
        <div class="api-card" @onclick='() => NavigateTo("device/battery")'>
            <div class="card-glow battery-glow"></div>
            <div class="card-header">
                <span class="card-icon battery-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="18" height="12" rx="2" ry="2"></rect><line x1="23" y1="11" x2="23" y2="13"></line></svg>
