@page "/ui/sheets"
@inject IToastService ToastService

<PageTitle>Bottom Sheets - GlassWASM</PageTitle>

<PageHeader Title="Sliding Bottom Sheets" 
            Description="Trigger sliding overlay sheets. Interact with drag handles or perform swipe-down gestures to dismiss panels." 
            ApiSupported="true" />

<div class="page-container">
    <div class="sheets-layout">
        <DemoCard Title="Sheet Controller">
            <p class="section-desc">Test sliding drawer modes typical of modern mobile device applications.</p>
            
            <div class="button-actions">
                <button class="btn-primary" @onclick="() => OpenSheet(false)">
                    Open Half Sheet (50vh)
                </button>
                
                <button class="btn-control btn-success" @onclick="() => OpenSheet(true)">
                    Open Full Sheet (85vh)
                </button>
            </div>
        </DemoCard>
    </div>

    <!-- Bottom Sheet Component Layer -->
    @if (_isOpen)
    {
        <div class="sheet-backdrop" @onclick="CloseSheet">
            <div class="sheet-container @(_isFullHeight ? "full-height" : "half-height")" 
                 style="@SheetTransformStyle"
                 @onclick:stopPropagation
                 @onpointerdown="OnPointerDown"
                 @onpointermove="OnPointerMove"
                 @onpointerup="OnPointerUp"
                 @onpointercancel="OnPointerUp">
                 
                <!-- Drag Handle -->
                <div class="sheet-handle-bar">
                    <div class="sheet-pill"></div>
                </div>

                <!-- Content Area -->
                <div class="sheet-body select-none">
                    <div class="sheet-header">
                        <h3>@(_isFullHeight ? "Terminal Detail Node" : "Status Summary")</h3>
                        <button class="close-btn-x" @onclick="CloseSheet">×</button>
                    </div>

                    <div class="sheet-content-scroll">
                        <p class="intro">You can swipe down on this modal card or pull the handle to dismiss it instantly.</p>
                        
                        <div class="sheet-items-demo">
                            <div class="demo-row">
                                <span class="lbl">Server Location:</span>
                                <span class="val">US-East Gateway #09</span>
                            </div>
                            <div class="demo-row">
                                <span class="lbl">Transfer Speed:</span>
                                <span class="val">884.2 Mbps</span>
                            </div>
                            <div class="demo-row">
                                <span class="lbl">Active Port:</span>
                                <span class="val highlight">SSL :443</span>
                            </div>
                            
                            @if (_isFullHeight)
                            {
                                <p class="extra-desc">
                                    This scrollable sheet content is designed to accommodate heavier diagnostic reports, charts, or detailed forms while retaining swipe dismissal parameters at any anchor point.
                                </p>
                                <div class="logs-mock">
                                    <code>[INFO] 19:42:01 - Initializing network adapter...</code>
                                    <code>[INFO] 19:42:02 - Handshake verified (TLS 1.3)</code>
                                    <code>[SUCCESS] 19:42:02 - Session tunnel established</code>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isOpen = false;
    private bool _isFullHeight = false;

    // Gesture State Tracker
    private bool _isDragging = false;
    private double _startY = 0;
    private double _currentY = 0;
    private double _offsetY = 0;

    private string SheetTransformStyle => _isDragging 
        ? $"transform: translateY({Math.Max(0, _offsetY)}px); transition: none;" 
        : $"transform: translateY(0); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);";

    private void OpenSheet(bool fullHeight)
    {
        _isFullHeight = fullHeight;
        _isOpen = true;
        _offsetY = 0;
        _isDragging = false;
        StateHasChanged();
    }

    private void CloseSheet()
    {
        _isOpen = false;
        StateHasChanged();
    }

    private void OnPointerDown(PointerEventArgs e)
    {
        // Only trigger drag if clicking the handle or upper area
        _isDragging = true;
        _startY = e.ClientY;
        _currentY = e.ClientY;
        _offsetY = 0;
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (!_isDragging) return;
        _currentY = e.ClientY;
        _offsetY = _currentY - _startY;
        StateHasChanged();
    }

    private void OnPointerUp(PointerEventArgs e)
    {
        if (!_isDragging) return;
        _isDragging = false;

        // Dismiss if swiped down far enough (e.g. 140px threshold)
        if (_offsetY > 140)
        {
            CloseSheet();
            ToastService.Info("Sheet dismissed via swipe gesture.");
        }
        else
        {
            _offsetY = 0;
        }
        StateHasChanged();
    }
}
