@page "/ui/theme"
@inject AppStateContainer AppState
@inject ILocalStorageService LocalStorage
@inject ClipboardService Clipboard
@inject IToastService ToastService

<PageTitle>Theme Engine - GlassWASM</PageTitle>

<PageHeader Title="Theme & Styling Engine" 
            Description="Inspect the active design tokens of the Glassmorphism design system, switch settings, and click swatch cells to copy colors." 
            ApiSupported="true" />

<div class="page-container">
    <div class="theme-layout">
        <!-- Left Side: Controls & Swatches -->
        <div class="theme-sidebar">
            <DemoCard Title="Configuration">
                <p class="section-desc">Select your preferred user interface scheme.</p>
                <div class="theme-selectors">
                    <button class="btn-control @(AppState.Theme == AppTheme.Dark ? "active" : "")" @onclick="() => SetThemeAsync(AppTheme.Dark)">
                        <span class="btn-icon">🌙</span>
                        <span>Dark Theme</span>
                    </button>
                    
                    <button class="btn-control @(AppState.Theme == AppTheme.Light ? "active" : "")" @onclick="() => SetThemeAsync(AppTheme.Light)">
                        <span class="btn-icon">☀️</span>
                        <span>Light Theme</span>
                    </button>
                </div>
            </DemoCard>

            <DemoCard Title="Color Palette Swatches">
                <p class="section-desc">Click any swatch to copy its hexadecimal/rgba token value.</p>
                <div class="swatches-grid">
                    <div class="swatch-card" @onclick='() => CopyColorAsync("var(--bg)", "#0c1117")'>
                        <div class="swatch-color color-bg"></div>
                        <div class="swatch-info">
                            <span class="swatch-name">Background</span>
                            <span class="swatch-var">--bg</span>
                        </div>
                    </div>

                    <div class="swatch-card" @onclick='() => CopyColorAsync("var(--surface)", "rgba(18, 24, 31, 0.6)")'>
                        <div class="swatch-color color-surface"></div>
                        <div class="swatch-info">
                            <span class="swatch-name">Surface Glass</span>
                            <span class="swatch-var">--surface</span>
                        </div>
                    </div>

                    <div class="swatch-card" @onclick='() => CopyColorAsync("var(--signal)", "#7ad1ff")'>
                        <div class="swatch-color color-signal"></div>
                        <div class="swatch-info">
                            <span class="swatch-name">Cyan Signal</span>
                            <span class="swatch-var">--signal</span>
                        </div>
                    </div>

                    <div class="swatch-card" @onclick='() => CopyColorAsync("var(--safety)", "#ffb82b")'>
                        <div class="swatch-color color-safety"></div>
                        <div class="swatch-info">
                            <span class="swatch-name">Amber Safety</span>
                            <span class="swatch-var">--safety</span>
                        </div>
                    </div>

                    <div class="swatch-card" @onclick='() => CopyColorAsync("var(--danger)", "#ff8370")'>
                        <div class="swatch-color color-danger"></div>
                        <div class="swatch-info">
                            <span class="swatch-name">Red Danger</span>
                            <span class="swatch-var">--danger</span>
                        </div>
                    </div>

                    <div class="swatch-card" @onclick='() => CopyColorAsync("var(--text)", "#e1e3e6")'>
                        <div class="swatch-color color-text"></div>
                        <div class="swatch-info">
                            <span class="swatch-name">Text Primary</span>
                            <span class="swatch-var">--text</span>
                        </div>
                    </div>
                </div>
            </DemoCard>
        </div>

        <!-- Right Side: Design Variables Table -->
        <div class="theme-main">
            <DemoCard Title="Active Token Mapping">
                <p class="section-desc">Design variables defined globally in <code>app.css</code> that update reactively when switching themes.</p>
                <div class="table-container">
                    <table class="variables-table">
                        <thead>
                            <tr>
                                <th>CSS Variable</th>
                                <th>Dark Theme Value</th>
                                <th>Light Theme Value</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>--bg</code></td>
                                <td class="mono">#0c1117</td>
                                <td class="mono">#f4f6fa</td>
                                <td>Core shell layout background</td>
                            </tr>
                            <tr>
                                <td><code>--surface</code></td>
                                <td class="mono">rgba(18,24,31,0.6)</td>
                                <td class="mono">rgba(255,255,255,0.72)</td>
                                <td>Frosted glass card surface</td>
                            </tr>
                            <tr>
                                <td><code>--line</code></td>
                                <td class="mono">rgba(122,209,255,0.12)</td>
                                <td class="mono">rgba(30,37,48,0.09)</td>
                                <td>Thin card border lines</td>
                            </tr>
                            <tr>
                                <td><code>--signal</code></td>
                                <td class="mono">#7ad1ff</td>
                                <td class="mono">#7ad1ff</td>
                                <td>Action button glows & borders</td>
                            </tr>
                            <tr>
                                <td><code>--safety</code></td>
                                <td class="mono">#ffb82b</td>
                                <td class="mono">#ffb82b</td>
                                <td>Warning badge highlight colors</td>
                            </tr>
                            <tr>
                                <td><code>--danger</code></td>
                                <td class="mono">#ff8370</td>
                                <td class="mono">#ff8370</td>
                                <td>Error state highlight colors</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </DemoCard>
        </div>
    </div>
</div>

@code {
    private async Task SetThemeAsync(AppTheme theme)
    {
        AppState.SetTheme(theme);
        await LocalStorage.SetItemAsync("theme", theme.ToString());
        ToastService.Success($"Theme switched to {theme} Mode.");
    }

    private async Task CopyColorAsync(string varName, string darkHex)
    {
        var activeColor = darkHex;
        if (AppState.Theme == AppTheme.Light)
        {
            if (varName == "var(--bg)") activeColor = "#f4f6fa";
            if (varName == "var(--surface)") activeColor = "rgba(255,255,255,0.72)";
            if (varName == "var(--text)") activeColor = "#1b222d";
        }
        
        var result = await Clipboard.WriteTextAsync(activeColor);
        if (result)
        {
            ToastService.Success($"Copied token {varName} ({activeColor}) to clipboard!");
        }
    }
}
