@page "/ui/feedback"
@inject IToastService ToastService

<PageTitle>Feedback & Dialogs - GlassWASM</PageTitle>

<PageHeader Title="Feedback & Dialog Systems" 
            Description="Trigger status toasts, prompt users with modal confirmations, and display skeleton load wrappers." 
            ApiSupported="true" />

<div class="page-container">
    <div class="feedback-grid">
        <!-- 1. Toast Controllers -->
        <DemoCard Title="Status Toast Triggers">
            <p class="section-desc">Push animated status cards into the application-wide floating notification container.</p>
            <div class="toast-buttons">
                <button class="btn-control" @onclick='() => ToastService.Info("Network synchronization active.")'>
                    🔵 Trigger Info
                </button>
                <button class="btn-control btn-success" @onclick='() => ToastService.Success("Telemetry backup saved successfully.")'>
                    🟢 Trigger Success
                </button>
                <button class="btn-control btn-warning" @onclick='() => ToastService.Warning("Device thermal margins approaching limits.")'>
                    🟡 Trigger Warning
                </button>
                <button class="btn-control btn-danger" @onclick='() => ToastService.Error("Process execution halted: stack overflow.")'>
                    🔴 Trigger Error
                </button>
            </div>
        </DemoCard>

        <!-- 2. Modal Confirmation -->
        <DemoCard Title="Modal Confirmations">
            <p class="section-desc">Prompt critical or destructive actions using a centered glassmorphism pop-up sheet.</p>
            <button class="btn-control btn-danger" @onclick="OpenConfirmModal">
                ⚠️ Purge Node Gateway
            </button>
        </DemoCard>

        <!-- 3. Skeleton Loading Toggle -->
        <DemoCard Title="Skeleton Loader States">
            <div class="card-header-toggle">
                <p class="section-desc">Toggle the loading state to switch between real data records and animated skeletons.</p>
                <label class="checkbox-container">
                    <input type="checkbox" @bind="_isLoading" />
                    <span class="checkmark"></span>
                    Simulate Loading State
                </label>
            </div>

            <div class="skeleton-sandbox">
                @if (_isLoading)
                {
                    <div class="skeleton-card animate-pulse">
                        <div class="skeleton-top">
                            <div class="skeleton-circle"></div>
                            <div class="skeleton-title"></div>
                        </div>
                        <div class="skeleton-body-line"></div>
                        <div class="skeleton-body-line short"></div>
                    </div>
                }
                else
                {
                    <div class="real-card animate-fade">
                        <div class="card-header-row">
                            <span class="avatar">⚡</span>
                            <h4>Operational Cluster Alpha</h4>
                        </div>
                        <p class="card-text">Status: <strong>Active</strong>. Bandwidth throughput is currently operating at nominal telemetry limits.</p>
                    </div>
                }
            </div>
        </DemoCard>
    </div>

    <!-- Confirm Modal Overlay -->
    @if (_isModalOpen)
    {
        <div class="modal-backdrop" @onclick="CloseConfirmModal">
            <div class="modal-container" @onclick:stopPropagation>
                <div class="modal-body select-none">
                    <span class="modal-warning-icon">⚠</span>
                    <h3>Confirm Destructive Action</h3>
                    <p>Are you sure you want to purge <strong>Cluster Alpha</strong>? This will delete all historical databases and is entirely irreversible.</p>
                </div>
                <div class="modal-actions">
                    <button class="btn-control btn-danger" @onclick="ConfirmPurge">
                        Purge Cluster
                    </button>
                    <button class="btn-control" @onclick="CloseConfirmModal">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isLoading = true;
    private bool _isModalOpen = false;

    private void OpenConfirmModal()
    {
        _isModalOpen = true;
        StateHasChanged();
    }

    private void CloseConfirmModal()
    {
        _isModalOpen = false;
        ToastService.Info("Purge operation cancelled.");
        StateHasChanged();
    }

    private void ConfirmPurge()
    {
        _isModalOpen = false;
        ToastService.Error("Cluster Alpha was purged from database nodes.");
        StateHasChanged();
    }
}
