@page "/ui/charts"
@inject IChartService ChartService
@inject IToastService ToastService

<PageTitle>Charts - GlassWASM</PageTitle>

<PageHeader Title="Canvas Analytics Charts" 
            Description="Visualize hardware state arrays using customized HTML5 canvas plots (Line, Bar, and Donut styles)." 
            ApiSupported="true" />

<div class="page-container">
    <div class="charts-actions">
        <button class="btn-primary" @onclick="RefreshChartsAsync">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
            Randomize Datasets
        </button>
    </div>

    <div class="charts-layout">
        <!-- 1. Line Chart -->
        <DemoCard Title="Processor Frequency History (Line)">
            <p class="chart-desc">Plots temporal CPU loading parameters over a rolling 6-point buffer.</p>
            <div class="chart-canvas-wrapper">
                <canvas id="line-chart-canvas" width="500" height="250"></canvas>
            </div>
        </DemoCard>

        <!-- 2. Bar Chart -->
        <DemoCard Title="Memory Buffer Allocations (Bar)">
            <p class="chart-desc">Compares active heap footprint sizes across garbage collector segments.</p>
            <div class="chart-canvas-wrapper">
                <canvas id="bar-chart-canvas" width="500" height="250"></canvas>
            </div>
        </DemoCard>

        <!-- 3. Donut Chart -->
        <DemoCard Title="Disk Storage Capacity (Donut)">
            <p class="chart-desc">Represents the split between allocated and free sector ranges.</p>
            <div class="chart-canvas-wrapper donut-box">
                <canvas id="donut-chart-canvas" width="300" height="250"></canvas>
            </div>
        </DemoCard>
    </div>
</div>

@code {
    // Dataset buffers
    private double[] _lineData = { 22.4, 45.8, 38.1, 72.9, 55.4, 88.0 };
    private string[] _lineLabels = { "10:00", "10:10", "10:20", "10:30", "10:40", "10:50" };

    private double[] _barData = { 110, 180, 240, 95, 140 };
    private string[] _barLabels = { "Gen0", "Gen1", "Gen2", "LOH", "POH" };

    private double[] _donutData = { 65.5, 34.5 };
    private string[] _donutLabels = { "Used", "Free" };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RenderAllChartsAsync();
        }
    }

    private async Task RenderAllChartsAsync()
    {
        try
        {
            await ChartService.DrawLineChartAsync("line-chart-canvas", _lineData, _lineLabels);
            await ChartService.DrawBarChartAsync("bar-chart-canvas", _barData, _barLabels);
            await ChartService.DrawDonutChartAsync("donut-chart-canvas", _donutData, _donutLabels);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error rendering canvas charts: " + ex.Message);
        }
    }

    private async Task RefreshChartsAsync()
    {
        var rand = new Random();
        
        // Randomize CPU line data
        for (int i = 0; i < _lineData.Length; i++)
        {
            _lineData[i] = 10 + (rand.NextDouble() * 85);
        }

        // Randomize Memory bar data
        for (int i = 0; i < _barData.Length; i++)
        {
            _barData[i] = 50 + rand.Next(250);
        }

        // Randomize Disk donut data
        var used = 20 + (rand.NextDouble() * 70);
        _donutData[0] = used;
        _donutData[1] = 100.0 - used;

        await RenderAllChartsAsync();
        ToastService.Success("Charts updated with randomized diagnostics.");
    }
}
