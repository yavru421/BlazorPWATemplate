@page "/ui/lists"
@using Microsoft.AspNetCore.Components.Web.Virtualization

<PageTitle>Virtualized Lists - GlassWASM</PageTitle>

<PageHeader Title="Virtualized Data Lists" 
            Description="Efficiently render datasets of 10,000+ items using Blazor Virtualize components. Filter records and watch skeleton state indicators." 
            ApiSupported="true" />

<div class="page-container">
    <DemoCard Title="Telemetry Node Registry">
        <p class="section-desc">Search and scroll through 10,000 simulated sensor records. Only visible elements are rendered to maximize CPU efficiency.</p>
        
        <!-- Search Filter Input -->
        <div class="filter-bar">
            <div class="search-input-wrapper">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" class="form-input search-field" placeholder="Search by Node ID or Status..." 
                       @bind="_searchQuery" @bind:event="oninput" />
            </div>
            
            <div class="dataset-stats">
                Total Matches: <strong>@FilteredCount</strong> / 10,000
            </div>
        </div>

        <!-- Virtualized List Container -->
        <div class="virtual-list-viewport">
            <Virtualize Items="FilteredRecords" Context="record" SpacerElement="div">
                <ItemContent>
                    <div class="record-row animate-fade">
                        <span class="record-avatar">📡</span>
                        <div class="record-details">
                            <h4>@record.Name</h4>
                            <span class="record-meta">UUID: @record.Uuid</span>
                        </div>
                        <div class="record-stats">
                            <span class="record-val">@record.Frequency.ToString("F2") GHz</span>
                            <span class="record-badge @record.Status.ToLower()">@record.Status</span>
                        </div>
                    </div>
                </ItemContent>
                
                <Placeholder>
                    <!-- Pulse Skeleton Loader -->
                    <div class="skeleton-row animate-pulse">
                        <div class="skeleton-avatar"></div>
                        <div class="skeleton-text-lines">
                            <div class="skeleton-line title"></div>
                            <div class="skeleton-line desc"></div>
                        </div>
                        <div class="skeleton-meta-lines">
                            <div class="skeleton-line value"></div>
                            <div class="skeleton-line badge"></div>
                        </div>
                    </div>
                </Placeholder>
            </Virtualize>

            @if (FilteredCount == 0)
            {
                <div class="no-records-banner">
                    <p>No telemetry records match your active search terms.</p>
                </div>
            }
        </div>
    </DemoCard>
</div>

@code {
    public class TelemetryRecord
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Uuid { get; set; } = "";
        public double Frequency { get; set; }
        public string Status { get; set; } = "";
    }

    private readonly List<TelemetryRecord> _allRecords = new(10000);
    private string _searchQuery = "";

    private ICollection<TelemetryRecord> FilteredRecords => string.IsNullOrWhiteSpace(_searchQuery)
        ? _allRecords
        : _allRecords.Where(r => r.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
                                 r.Status.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                                 r.Uuid.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    private int FilteredCount => FilteredRecords.Count;

    protected override void OnInitialized()
    {
        var random = new Random();
        var statuses = new[] { "Active", "Offline", "Standby" };

        for (int i = 1; i <= 10000; i++)
        {
            _allRecords.Add(new TelemetryRecord
            {
                Id = i,
                Name = $"Sensor Node #{i:D5}",
                Uuid = Guid.NewGuid().ToString().Substring(0, 13),
                Frequency = 2.4 + (random.NextDouble() * 3.6), // 2.4 to 6.0 GHz range
                Status = statuses[random.Next(statuses.Length)]
            });
        }
    }
}
