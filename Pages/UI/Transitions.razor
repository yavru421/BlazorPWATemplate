@page "/ui/transitions"
@inject ClipboardService Clipboard
@inject IToastService ToastService

<PageTitle>Transitions - GlassWASM</PageTitle>

<PageHeader Title="Transitions & Animations" 
            Description="Explore modern CSS animations. Select a style class from the list to animate entering cards in real time." 
            ApiSupported="true" />

<div class="page-container">
    <div class="transitions-layout">
        <!-- Control Panel -->
        <div class="control-panel">
            <DemoCard Title="Select Animation Effect">
                <div class="form-group">
                    <label for="anim-select">Animation Type</label>
                    <select id="anim-select" class="form-select" @bind="_activeAnimation" @bind:after="TriggerRebuild">
                        <option value="fade">Fade In</option>
                        <option value="slide-up">Slide Up & Fade</option>
                        <option value="slide-right">Slide Right & Fade</option>
                        <option value="scale">Zoom Scale</option>
                        <option value="flip">3D Perspective Flip</option>
                    </select>
                </div>

                <div class="panel-actions">
                    <button class="btn-primary" @onclick="TriggerRebuild">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                        Replay Animation
                    </button>
                </div>
            </DemoCard>

            <DemoCard Title="CSS Snippet">
                <p class="section-desc">Copy this CSS class to implement the chosen transition effect in your projects.</p>
                <div class="snippet-box">
                    <pre><code>@CssSnippet</code></pre>
                    <button class="copy-btn" @onclick="CopySnippetAsync">Copy</button>
                </div>
            </DemoCard>
        </div>

        <!-- Sandbox Display -->
        <div class="sandbox-panel">
            <DemoCard Title="Sandbox Preview">
                <div class="preview-deck">
                    @if (_showDeck)
                    {
                        @for (int i = 1; i <= 3; i++)
                        {
                            var index = i;
                            <div class="preview-card anim-@_activeAnimation" style="animation-delay: @(index * 0.15)s">
                                <span class="card-num">#0@index</span>
                                <h3>Frosted Glass Panel</h3>
                                <p>Rendered dynamically with transition delays to display fluid staggered entry.</p>
                            </div>
                        }
                    }
                </div>
            </DemoCard>
        </div>
    </div>
</div>

@code {
    private string _activeAnimation = "fade";
    private bool _showDeck = true;

    private void TriggerRebuild()
    {
        _showDeck = false;
        StateHasChanged();
        // Short delay to force the DOM to clear and re-render elements, triggering CSS entry animations
        _ = Task.Delay(50).ContinueWith(_ =>
        {
            _showDeck = true;
            InvokeAsync(StateHasChanged);
        });
    }

    private string CssSnippet => _activeAnimation switch
    {
        "fade" => 
@".anim-fade {
    animation: fadeIn 0.4s ease-out forwards;
}
@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}",
        "slide-up" => 
@".anim-slide-up {
    animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
@keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
}",
        "slide-right" => 
@".anim-slide-right {
    animation: slideRight 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
@keyframes slideRight {
    from { opacity: 0; transform: translateX(-24px); }
    to { opacity: 1; transform: translateX(0); }
}",
        "scale" => 
@".anim-scale {
    animation: zoomScale 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes zoomScale {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
}",
        "flip" => 
@".anim-flip {
    transform-style: preserve-3d;
    backface-visibility: hidden;
    animation: flip3d 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}
@keyframes flip3d {
    from { opacity: 0; transform: rotateY(-90deg); }
    to { opacity: 1; transform: rotateY(0deg); }
}",
        _ => ""
    };

    private async Task CopySnippetAsync()
    {
        var result = await Clipboard.WriteTextAsync(CssSnippet);
        if (result)
        {
            ToastService.Success("CSS snippet copied to clipboard.");
        }
    }
}
