@page "/ui/forms"
@using System.ComponentModel.DataAnnotations
@inject IToastService ToastService

<PageTitle>Form Validation - GlassWASM</PageTitle>

<PageHeader Title="Input Fields & Validation" 
            Description="Explore glassmorphic form elements and test live validation using Blazor's EditForm model bindings." 
            ApiSupported="true" />

<div class="page-container">
    <div class="forms-layout">
        <!-- Form Panel -->
        <div class="form-card-wrapper">
            <DemoCard Title="Node Configuration Board">
                <EditForm Model="_model" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit">
                    <DataAnnotationsValidator />

                    <div class="form-grid">
                        <!-- Node Name (Required, Range validation) -->
                        <div class="form-group">
                            <label for="node-name">Sensor Node Name</label>
                            <InputText id="node-name" class="form-input" @bind-Value="_model.NodeName" placeholder="e.g. Gateway Alpha" />
                            <ValidationMessage For="() => _model.NodeName" class="val-error" />
                        </div>

                        <!-- Region Selector -->
                        <div class="form-group">
                            <label for="node-region">Server Region</label>
                            <InputSelect id="node-region" class="form-select" @bind-Value="_model.Region">
                                <option value="">Select a region...</option>
                                <option value="us-east">US East (N. Virginia)</option>
                                <option value="eu-west">EU West (Ireland)</option>
                                <option value="ap-south">Asia Pacific (Mumbai)</option>
                            </InputSelect>
                            <ValidationMessage For="() => _model.Region" class="val-error" />
                        </div>

                        <!-- Schedule Date (DateTime validation) -->
                        <div class="form-group">
                            <label for="node-date">Next Calibration Date</label>
                            <InputDate id="node-date" class="form-input" @bind-Value="_model.CalibrationDate" />
                            <ValidationMessage For="() => _model.CalibrationDate" class="val-error" />
                        </div>

                        <!-- LED Color (Color Picker) -->
                        <div class="form-group color-picker-group">
                            <label for="node-color">Telemetry LED Glow</label>
                            <div class="color-picker-row">
                                <input id="node-color" type="color" class="form-color-picker" @bind="_model.LedColor" />
                                <span class="color-hex-val monospace">@_model.LedColor</span>
                            </div>
                        </div>

                        <!-- Range Throttle Slider -->
                        <div class="form-group range-group">
                            <label for="node-throttle">Transmission Throttle: @_model.Throttle%</label>
                            <input id="node-throttle" type="range" min="10" max="100" class="form-range" @bind="_model.Throttle" @bind:event="oninput" />
                            <span class="range-helper">Throttles frequency output levels from 10% - 100% bandwidth.</span>
                        </div>

                        <!-- Switch / Checkbox switches -->
                        <div class="form-group checkbox-group">
                            <label class="checkbox-container">
                                <InputCheckbox @bind-Value="_model.EnableLogging" />
                                <span class="checkmark"></span>
                                Log diagnostic anomalies to database
                            </label>
                        </div>
                    </div>

                    <div class="form-submit-actions">
                        <button type="submit" class="btn-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                            Save Configurations
                        </button>
                    </div>
                </EditForm>
            </DemoCard>
        </div>

        <!-- Output JSON Panel -->
        <div class="preview-panel">
            <DemoCard Title="JSON Serialized Output">
                <p class="section-desc">Reactive model state serialization.</p>
                <div class="json-code-box">
                    <pre><code>@SerializedModel</code></pre>
                </div>
            </DemoCard>
        </div>
    </div>
</div>

@code {
    public class SettingsFormModel
    {
        [Required(ErrorMessage = "Sensor Node Name is required.")]
        [StringLength(20, MinimumLength = 3, ErrorMessage = "Name must be between 3 and 20 characters.")]
        public string NodeName { get; set; } = "";

        [Required(ErrorMessage = "Please select an operational region.")]
        public string Region { get; set; } = "";

        [Required(ErrorMessage = "Calibration date is required.")]
        public DateTime? CalibrationDate { get; set; } = DateTime.Today.AddDays(7);

        public string LedColor { get; set; } = "#7ad1ff";

        [Range(20, 80, ErrorMessage = "Throttle safety limits are 20% to 80%.")]
        public int Throttle { get; set; } = 50;

        public bool EnableLogging { get; set; } = true;
    }

    private readonly SettingsFormModel _model = new();

    private string SerializedModel => System.Text.Json.JsonSerializer.Serialize(_model, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });

    private void HandleValidSubmit()
    {
        ToastService.Success($"Node config '{_model.NodeName}' saved successfully!");
    }

    private void HandleInvalidSubmit()
    {
        ToastService.Error("Form validation failed. Please review errors marked in red.");
    }
}
