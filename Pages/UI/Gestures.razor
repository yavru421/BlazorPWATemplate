@page "/ui/gestures"
@inject IToastService ToastService

<PageTitle>Gestures & Swiping - GlassWASM</PageTitle>

<PageHeader Title="Gesture Sandboxes" 
            Description="Interact with high-fidelity input containers. Swipe card decks left/right or pull-to-refresh lists with spring physics." 
            ApiSupported="true" />

<div class="page-container">
    <div class="gestures-grid">
        <!-- Panel 1: Tinder Swipeable Deck -->
        <DemoCard Title="Tinder-Swipe Card Deck">
            <p class="section-desc">Drag or flick the card left to reject, or right to approve. Snaps back on release if distance threshold is not met.</p>
            
            <div class="swipe-sandbox">
                <div class="card-deck-container">
                    @if (_currentCardIndex < _deckCards.Count)
                    {
                        var card = _deckCards[_currentCardIndex];
                        <!-- Active Card -->
                        <div class="swipe-card active-card" 
                             style="@ActiveCardStyle"
                             @onpointerdown="OnCardPointerDown"
                             @onpointermove="OnCardPointerMove"
                             @onpointerup="OnCardPointerUp"
                             @onpointercancel="OnCardPointerUp">
                            
                            <div class="card-bg-gradient" style="background: @card.Gradient;"></div>
                            <div class="card-inner-content select-none">
                                <span class="card-badge">Module</span>
                                <h2>@card.Title</h2>
                                <p>@card.Description</p>
                                
                                <div class="swipe-hints">
                                    <span class="hint reject @(CardRejectIntensityClass)">REJECT</span>
                                    <span class="hint approve @(CardApproveIntensityClass)">APPROVE</span>
                                </div>
                            </div>
                        </div>

                        <!-- Next Card Preview (stacked behind) -->
                        @if (_currentCardIndex + 1 < _deckCards.Count)
                        {
                            var nextCard = _deckCards[_currentCardIndex + 1];
                            <div class="swipe-card card-underneath">
                                <div class="card-bg-gradient" style="background: @nextCard.Gradient; opacity: 0.35;"></div>
                                <div class="card-inner-content">
                                    <span class="card-badge">Next Up</span>
                                    <h2>@nextCard.Title</h2>
                                    <p>@nextCard.Description</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-deck animate-scale-up">
                            <span>🎉</span>
                            <h3>All Cards Swiped!</h3>
                            <button class="btn-primary" @onclick="ResetDeck">Reset Deck</button>
                        </div>
                    }
                </div>
            </div>
        </DemoCard>

        <!-- Panel 2: Pull-To-Refresh Sandbox -->
        <DemoCard Title="Pull-To-Refresh Container">
            <p class="section-desc">Drag down inside the feed area below to trigger a mock data refresh. Releases with a loading indicator.</p>
            
            <div class="pull-refresh-container"
                 @onpointerdown="OnPullPointerDown"
                 @onpointermove="OnPullPointerMove"
                 @onpointerup="OnPullPointerUp"
                 @onpointercancel="OnPullPointerUp">
                 
                <!-- Pull Indicator -->
                <div class="pull-indicator" style="@PullIndicatorStyle">
                    @if (_isRefreshing)
                    {
                        <div class="spinner"></div>
                    }
                    else
                    {
                        <div class="pull-arrow" style="transform: rotate(@(Math.Min(180, _pullDistance * 2.2))deg)">↓</div>
                    }
                </div>

                <!-- Feed Content -->
                <div class="feed-content select-none" style="@FeedOffsetStyle">
                    @foreach (var item in _feedItems)
                    {
                        <div class="feed-item">
                            <div class="feed-dot"></div>
                            <div class="feed-details">
                                <span class="feed-time">@item.Time</span>
                                <h4>@item.Header</h4>
                                <p>@item.Detail</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </DemoCard>
    </div>
</div>

@code {
    // ----------------------------------------------------
    // 1. Swiping Card Deck Logic
    // ----------------------------------------------------
    public class SwipeCardData
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Gradient { get; set; } = "";
    }

    private readonly List<SwipeCardData> _deckCards = new()
    {
        new SwipeCardData { Title = "Glassmorphism UI Core", Description = "A visual aesthetic layer composed of frosted panels, thin borders, and saturated mesh nodes.", Gradient = "linear-gradient(135deg, #7ad1ff, #0056b3)" },
        new SwipeCardData { Title = "WebAssembly PWA", Description = "Build client-side applications that install to home screens and cache assets locally via service workers.", Gradient = "linear-gradient(135deg, #ffb82b, #d47a00)" },
        new SwipeCardData { Title = "Hardware Telemetry", Description = "Acquire live coordinates, screen wake locks, and vibration patterns directly through standard browser Web APIs.", Gradient = "linear-gradient(135deg, #ff8370, #c0292b)" },
        new SwipeCardData { Title = "Canvas Audiometrics", Description = "Access mic inputs and calculate real-time frequency amplitudes rendered dynamically via HTML5 Canvas.", Gradient = "linear-gradient(135deg, #b47aff, #5a1099)" }
    };

    private int _currentCardIndex = 0;
    
    // Card pointer tracking variables
    private bool _cardDragging = false;
    private double _cardStartX = 0;
    private double _cardStartY = 0;
    private double _cardCurrentX = 0;
    private double _cardCurrentY = 0;
    private double _cardOffsetX = 0;
    private double _cardOffsetY = 0;

    private string ActiveCardStyle
    {
        get
        {
            if (!_cardDragging)
            {
                return "transform: translate(0px, 0px) rotate(0deg); transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.2);";
            }
            
            // Calculate proportional rotation to drag distance
            double rotation = _cardOffsetX * 0.08;
            return $"transform: translate({_cardOffsetX}px, {_cardOffsetY}px) rotate({rotation}deg); transition: none;";
        }
    }

    private string CardApproveIntensityClass => _cardOffsetX > 30 ? "visible" : "";
    private string CardRejectIntensityClass => _cardOffsetX < -30 ? "visible" : "";

    private void OnCardPointerDown(PointerEventArgs e)
    {
        _cardDragging = true;
        _cardStartX = e.ClientX;
        _cardStartY = e.ClientY;
        _cardCurrentX = e.ClientX;
        _cardCurrentY = e.ClientY;
        _cardOffsetX = 0;
        _cardOffsetY = 0;
    }

    private void OnCardPointerMove(PointerEventArgs e)
    {
        if (!_cardDragging) return;
        _cardCurrentX = e.ClientX;
        _cardCurrentY = e.ClientY;
        _cardOffsetX = _cardCurrentX - _cardStartX;
        _cardOffsetY = _cardCurrentY - _cardStartY;
        StateHasChanged();
    }

    private void OnCardPointerUp(PointerEventArgs e)
    {
        if (!_cardDragging) return;
        _cardDragging = false;

        // Swipe threshold: 140 pixels horizontal displacement
        if (_cardOffsetX > 140)
        {
            // Approve swipe
            SwipeDismissCard(true);
        }
        else if (_cardOffsetX < -140)
        {
            // Reject swipe
            SwipeDismissCard(false);
        }
        else
        {
            // Reset position
            _cardOffsetX = 0;
            _cardOffsetY = 0;
        }
        StateHasChanged();
    }

    private void SwipeDismissCard(bool approved)
    {
        ToastService.Success(approved ? "Approved Card!" : "Rejected Card.");
        _currentCardIndex++;
        _cardOffsetX = 0;
        _cardOffsetY = 0;
    }

    private void ResetDeck()
    {
        _currentCardIndex = 0;
        StateHasChanged();
    }

    // ----------------------------------------------------
    // 2. Pull-To-Refresh Logic
    // ----------------------------------------------------
    public class FeedItemData
    {
        public string Time { get; set; } = "";
        public string Header { get; set; } = "";
        public string Detail { get; set; } = "";
    }

    private readonly List<FeedItemData> _feedItems = new()
    {
        new FeedItemData { Time = "Just now", Header = "Telemetry Signal Normal", Detail = "Database heartbeats returning 200 OK signals." },
        new FeedItemData { Time = "12 mins ago", Header = "PWA Sync Event Complete", Detail = "Background database rows synced to local cache." },
        new FeedItemData { Time = "1 hour ago", Header = "Vibration API Test Complete", Detail = "Triggered pattern sequence request (100-50-200ms)." }
    };

    private bool _pullDragging = false;
    private double _pullStartY = 0;
    private double _pullCurrentY = 0;
    private double _pullDistance = 0;
    private bool _isRefreshing = false;

    private string PullIndicatorStyle => _pullDistance > 10 || _isRefreshing
        ? $"height: {Math.Min(80, _pullDistance + (_isRefreshing ? 60 : 0))}px; opacity: 1; transition: none;"
        : "height: 0px; opacity: 0; transition: height 0.3s ease, opacity 0.3s ease;";

    private string FeedOffsetStyle => _pullDistance > 0 && !_isRefreshing
        ? $"transform: translateY({Math.Min(60, _pullDistance * 0.65)}px); transition: none;"
        : "transform: translateY(0px); transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);";

    private void OnPullPointerDown(PointerEventArgs e)
    {
        if (_isRefreshing) return;
        _pullDragging = true;
        _pullStartY = e.ClientY;
        _pullCurrentY = e.ClientY;
        _pullDistance = 0;
    }

    private void OnPullPointerMove(PointerEventArgs e)
    {
        if (!_pullDragging) return;
        _pullCurrentY = e.ClientY;
        var diff = _pullCurrentY - _pullStartY;
        // Limit pull to swipe down gestures only
        _pullDistance = Math.Max(0, diff);
        StateHasChanged();
    }

    private async Task OnPullPointerUp(PointerEventArgs e)
    {
        if (!_pullDragging) return;
        _pullDragging = false;

        // Threshold to refresh: 70 pixels of downward drag
        if (_pullDistance > 70)
        {
            _isRefreshing = true;
            _pullDistance = 60; // Keep space open for spinner
            ToastService.Info("Refreshing feed logs...");
            StateHasChanged();

            // Simulate server refresh delay
            await Task.Delay(2000);

            // Prepend new item
            _feedItems.Insert(0, new FeedItemData
            {
                Time = "Just now",
                Header = "Refreshed Node Log",
                Detail = "Feed logs updated via pull-to-refresh pull gesture."
            });

            _isRefreshing = false;
            _pullDistance = 0;
            ToastService.Success("Feed up to date!");
        }
        else
        {
            _pullDistance = 0;
        }
        StateHasChanged();
    }
}
