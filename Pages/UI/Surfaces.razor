@page "/ui/surfaces"
@inject AppStateContainer AppState

<PageTitle>Surfaces - GlassWASM</PageTitle>

<PageHeader Title="Surfaces & Glass Elements" 
            Description="Inspect standard interface frames, elevated panels, warning sheets, and configure glass settings dynamically." 
            ApiSupported="true" />

<div class="page-container">
    <!-- Interactive Glass Customizer Sandbox -->
    <div class="sandbox-section">
        <div class="customizer-controls">
            <DemoCard Title="Glass Settings">
                <p class="section-desc">Tune CSS variables live to inspect transparency balances.</p>
                
                <div class="slider-group">
                    <label>Backdrop Blur: @_blurRadius px</label>
                    <input type="range" min="0" max="32" @bind-value="_blurRadius" @bind-value:event="oninput" />
                </div>

                <div class="slider-group">
                    <label>Surface Opacity: @((int)(_opacity * 100))%</label>
                    <input type="range" min="0" max="100" @bind-value="_opacityPercentage" @bind-value:event="oninput" />
                </div>

                <div class="slider-group">
                    <label>Border Opacity: @((int)(_borderOpacity * 100))%</label>
                    <input type="range" min="0" max="100" @bind-value="_borderOpacityPercentage" @bind-value:event="oninput" />
                </div>
            </DemoCard>
        </div>

        <div class="customizer-preview">
            <!-- Animated decorative nodes behind glass to show transparency -->
            <div class="glass-bg-art">
                <div class="art-circle art-1"></div>
                <div class="art-circle art-2"></div>
                <div class="art-circle art-3"></div>
            </div>

            <div class="interactive-glass-card" style="@InteractiveGlassStyle">
                <h3>Glassmorphism Sandbox</h3>
                <p>Customize sliders on the left to watch how backdrop blur filters and surface alpha levels blend into background graphics.</p>
                <div class="card-footer-tokens">
                    <code>backdrop-filter: blur(@(_blurRadius)px);</code>
                    <code>background: rgba(..., @_opacity.ToString("F2"));</code>
                </div>
            </div>
        </div>
    </div>

    <!-- Static Surface Types Grid -->
    <div class="surfaces-static-grid">
        <!-- Standard Surface -->
        <div class="surface-demo-card surface-standard">
            <span class="surface-tag">Standard Surface</span>
            <h4>Frictionless Surface</h4>
            <p>Our core glass style layer. Low-key contrast that sits comfortably over light or dark canvases.</p>
        </div>

        <!-- Strong Surface -->
        <div class="surface-demo-card surface-strong">
            <span class="surface-tag">Strong Surface</span>
            <h4>Elevated Deck</h4>
            <p>Deeper backing layer meant for inputs, code snippet editors, and layouts requiring high-contrast context boundaries.</p>
        </div>

        <!-- Success Alert Surface -->
        <div class="surface-demo-card status-success">
            <span class="surface-tag">Success state</span>
            <h4>Task Completed</h4>
            <p>Safe operation signals. Combines light green glows with active border highlights.</p>
        </div>

        <!-- Warning Alert Surface -->
        <div class="surface-demo-card status-warning">
            <span class="surface-tag">Warning state</span>
            <h4>Action Warning</h4>
            <p>Safety parameters breached. Alerting users of required inputs or hardware limits.</p>
        </div>

        <!-- Danger Alert Surface -->
        <div class="surface-demo-card status-danger">
            <span class="surface-tag">Danger state</span>
            <h4>System Alert</h4>
            <p>Severe warning states or process interruptions requiring immediate action.</p>
        </div>
    </div>
</div>

@code {
    private int _blurRadius = 16;
    
    private int _opacityPercentage = 40; // Default 40%
    private double _opacity => _opacityPercentage / 100.0;

    private int _borderOpacityPercentage = 12; // Default 12%
    private double _borderOpacity => _borderOpacityPercentage / 100.0;

    private string InteractiveGlassStyle
    {
        get
        {
            var surfaceBg = AppState.Theme == AppTheme.Light 
                ? $"rgba(255, 255, 255, {_opacity:F2})" 
                : $"rgba(18, 24, 31, {_opacity:F2})";
                
            var borderBg = AppState.Theme == AppTheme.Light
                ? $"rgba(30, 37, 48, {_borderOpacity:F2})"
                : $"rgba(122, 209, 255, {_borderOpacity:F2})";

            return $"background: {surfaceBg}; backdrop-filter: blur({_blurRadius}px); -webkit-backdrop-filter: blur({_blurRadius}px); border-color: {borderBg};";
        }
    }

}

