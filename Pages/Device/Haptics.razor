@page "/device/haptics"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Haptic Feedback - GlassWASM</PageTitle>

<PageHeader Title="Haptic Feedback" 
            Description="Trigger physical phone vibration patterns (taps, warning shakes, success tones, heartbeat pulses) or construct custom duration arrays." 
            ApiSupported="_isSupported" 
            FeatureName="Vibration" />

<div class="page-container">
    <PermissionGate @ref="_gate" 
                    IsSupported="_isSupported" 
                    PermissionName="vibrate" 
                    PermissionLabel="Vibration"
                    Description="This page requires access to the device vibration engine. Note that vibration is typically supported on mobile devices and ignored on desktop."
                    RequestPermission="TriggerSingleTap">
        
        <div class="haptics-grid">
            <!-- Preset Vibration Patterns -->
            <DemoCard Title="Standard Patterns">
                <p class="section-desc">Tap the buttons below to test typical hardware alert patterns.</p>
                <div class="patterns-grid">
                    <button class="btn-control haptic-btn" @onclick="() => TriggerVibration(50)">
                        <span class="btn-icon">⚡</span>
                        <span class="btn-label">Single Tap</span>
                        <span class="btn-duration">50ms</span>
                    </button>

                    <button class="btn-control haptic-btn" @onclick="() => TriggerPattern(new[] { 50, 80, 50 })">
                        <span class="btn-icon">⚡⚡</span>
                        <span class="btn-label">Double Tap</span>
                        <span class="btn-duration">50-80-50ms</span>
                    </button>

                    <button class="btn-control haptic-btn btn-success" @onclick="() => TriggerPattern(new[] { 100, 50, 200 })">
                        <span class="btn-icon">✓</span>
                        <span class="btn-label">Success</span>
                        <span class="btn-duration">100-50-200ms</span>
                    </button>

                    <button class="btn-control haptic-btn btn-warning" @onclick="() => TriggerPattern(new[] { 150, 100, 150 })">
                        <span class="btn-icon">⚠</span>
                        <span class="btn-label">Warning</span>
                        <span class="btn-duration">150-100-150ms</span>
                    </button>

                    <button class="btn-control haptic-btn btn-danger" @onclick="() => TriggerPattern(new[] { 200, 80, 200, 80, 400 })">
                        <span class="btn-icon">✗</span>
                        <span class="btn-label">Error Alert</span>
                        <span class="btn-duration">Multi-pulse</span>
                    </button>

                    <button class="btn-control haptic-btn btn-heartbeat" @onclick="() => TriggerPattern(new[] { 100, 100, 150, 300, 100, 100, 150 })">
                        <span class="btn-icon">❤</span>
                        <span class="btn-label">Heartbeat</span>
                        <span class="btn-duration">Rhythmic</span>
                    </button>
                </div>
            </DemoCard>

            <!-- Custom Sequence Input -->
            <DemoCard Title="Custom Vibration Sequencer">
                <p class="section-desc">Design custom vibrations using a comma-separated list of durations (vibrate, pause, vibrate, etc.) in milliseconds.</p>
                
                <div class="custom-sequence-form">
                    <div class="form-group">
                        <label for="custom-sequence">Sequence Pattern</label>
                        <input id="custom-sequence" type="text" class="form-input" @bind="_customSequence" placeholder="e.g. 200, 100, 200, 100, 500" />
                        <span class="helper-text">Alternates vibrate (ms) and pause (ms). e.g., '200, 100, 500' will vibrate 200ms, wait 100ms, then vibrate 500ms.</span>
                    </div>

                    <div class="form-actions">
                        <button class="btn-primary" @onclick="TriggerCustomPattern">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            Execute Sequence
                        </button>
                    </div>
                </div>
            </DemoCard>
        </div>
    </PermissionGate>
</div>

@code {
    private PermissionGate? _gate;
    private bool _isSupported = true;
    private IJSObjectReference? _hapticsModule;
    private string _customSequence = "200, 100, 200, 100, 500";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("haptics") && caps["haptics"];
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task InitModuleAsync()
    {
        _hapticsModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/haptics.module.js");
    }

    private async Task TriggerSingleTap()
    {
        await TriggerVibration(50);
    }

    private async Task TriggerVibration(int durationMs)
    {
        await InitModuleAsync();
        if (_hapticsModule != null)
        {
            await _hapticsModule.InvokeVoidAsync("vibrate", durationMs);
            _gate?.ForceStatus("granted");
            ToastService.Success($"Vibrated {durationMs}ms.");
        }
    }

    private async Task TriggerPattern(int[] pattern)
    {
        await InitModuleAsync();
        if (_hapticsModule != null)
        {
            await _hapticsModule.InvokeVoidAsync("vibratePattern", pattern);
            _gate?.ForceStatus("granted");
            ToastService.Success("Vibration pattern executed.");
        }
    }

    private async Task TriggerCustomPattern()
    {
        if (string.IsNullOrWhiteSpace(_customSequence))
        {
            ToastService.Warning("Please enter a valid sequence pattern.");
            return;
        }

        try
        {
            var parts = _customSequence.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            var pattern = parts.Select(int.Parse).ToArray();

            if (pattern.Length == 0)
            {
                throw new FormatException("Sequence must contain at least one duration.");
            }

            await TriggerPattern(pattern);
        }
        catch (Exception ex)
        {
            ToastService.Error("Invalid sequence format: " + ex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hapticsModule != null)
        {
            await _hapticsModule.DisposeAsync();
        }
    }
}
