@page "/device/motion"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Device Motion API - GlassWASM</PageTitle>

<PageHeader Title="Device Motion & Gyroscope" 
            Description="Retrieve real-time accelerometer and gyroscope data. Witness a 3D CSS wireframe phone respond dynamically to physical tilt." 
            ApiSupported="_isSupported" />

<div class="page-container">
    <PermissionGate @ref="_gate" 
                    IsSupported="_isSupported" 
                    PermissionName="accelerometer" 
                    PermissionLabel="Device Motion"
                    Description="This page requires access to your device's motion sensors to read gyroscope and accelerometer coordinates."
                    RequestPermission="RequestMotionPermissionAsync">
        
        <div class="motion-layout">
            <!-- Left Side: Controls & Numerical Data -->
            <div class="motion-sidebar">
                <DemoCard Title="Sensor Readings">
                    <div class="motion-actions">
                        <button class="btn-control @(_isListening ? "btn-danger" : "btn-success")" @onclick="ToggleSensorListening">
                            @if (_isListening)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
                                <span>Stop Sensors</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                <span>Start Sensors</span>
                            }
                        </button>
                    </div>

                    <div class="metrics-grid">
                        <div class="metric-section">
                            <h4>Acceleration (excl. Gravity)</h4>
                            <div class="metric-row">
                                <span class="lbl">X-Axis</span>
                                <span class="val">@_accelX.ToString("F2") m/s²</span>
                            </div>
                            <div class="metric-row">
                                <span class="lbl">Y-Axis</span>
                                <span class="val">@_accelY.ToString("F2") m/s²</span>
                            </div>
                            <div class="metric-row">
                                <span class="lbl">Z-Axis</span>
                                <span class="val">@_accelZ.ToString("F2") m/s²</span>
                            </div>
                        </div>

                        <div class="metric-section">
                            <h4>Acceleration (incl. Gravity)</h4>
                            <div class="metric-row">
                                <span class="lbl">X-Axis</span>
                                <span class="val">@_gravX.ToString("F2") m/s²</span>
                            </div>
                            <div class="metric-row">
                                <span class="lbl">Y-Axis</span>
                                <span class="val">@_gravY.ToString("F2") m/s²</span>
                            </div>
                            <div class="metric-row">
                                <span class="lbl">Z-Axis</span>
                                <span class="val">@_gravZ.ToString("F2") m/s²</span>
                            </div>
                        </div>

                        <div class="metric-section">
                            <h4>Rotation Rate</h4>
                            <div class="metric-row">
                                <span class="lbl">Alpha (Z)</span>
                                <span class="val">@_rotAlpha.ToString("F1")°/s</span>
                            </div>
                            <div class="metric-row">
                                <span class="lbl">Beta (X)</span>
                                <span class="val">@_rotBeta.ToString("F1")°/s</span>
                            </div>
                            <div class="metric-row">
                                <span class="lbl">Gamma (Y)</span>
                                <span class="val">@_rotGamma.ToString("F1")°/s</span>
                            </div>
                        </div>
                    </div>
                </DemoCard>
            </div>

            <!-- Right Side: 3D Wireframe Canvas -->
            <div class="motion-main">
                <DemoCard Title="3D Tilt Simulation">
                    <p class="simulation-note">If using a desktop, drag the sliders below to simulate physical device tilt.</p>
                    
                    <div class="scene-container">
                        <div class="perspective-box" style="transform: rotateX(@(_tiltX)deg) rotateY(@(_tiltY)deg) rotateZ(@(_tiltZ)deg);">
                            <div class="phone-wireframe">
                                <div class="phone-face front">
                                    <div class="screen-glow-3d"></div>
                                    <div class="camera-notch"></div>
                                    <div class="brand-logo">G</div>
                                </div>
                                <div class="phone-face back"></div>
                                <div class="phone-side left"></div>
                                <div class="phone-side right"></div>
                                <div class="phone-side top"></div>
                                <div class="phone-side bottom"></div>
                            </div>
                        </div>
                    </div>

                    <div class="manual-simulators">
                        <div class="slider-group">
                            <label>Tilt X (Pitch): @_tiltX.ToString("F0")°</label>
                            <input type="range" min="-90" max="90" @bind-value="_tiltX" @bind-value:event="oninput" disabled="@_isListening" />
                        </div>
                        <div class="slider-group">
                            <label>Tilt Y (Roll): @_tiltY.ToString("F0")°</label>
                            <input type="range" min="-90" max="90" @bind-value="_tiltY" @bind-value:event="oninput" disabled="@_isListening" />
                        </div>
                        <div class="slider-group">
                            <label>Tilt Z (Yaw): @_tiltZ.ToString("F0")°</label>
                            <input type="range" min="-180" max="180" @bind-value="_tiltZ" @bind-value:event="oninput" disabled="@_isListening" />
                        </div>
                    </div>
                </DemoCard>
            </div>
        </div>
    </PermissionGate>
</div>

@code {
    public class MotionData
    {
        public double AccelerationX { get; set; }
        public double AccelerationY { get; set; }
        public double AccelerationZ { get; set; }
        public double AccelerationIncludingGravityX { get; set; }
        public double AccelerationIncludingGravityY { get; set; }
        public double AccelerationIncludingGravityZ { get; set; }
        public double RotationRateAlpha { get; set; }
        public double RotationRateBeta { get; set; }
        public double RotationRateGamma { get; set; }
        public double Interval { get; set; }
    }

    private PermissionGate? _gate;
    private bool _isSupported = true;
    private bool _isListening = false;
    private IJSObjectReference? _motionModule;
    private DotNetObjectReference<Motion>? _selfReference;

    // Readings
    private double _accelX, _accelY, _accelZ;
    private double _gravX, _gravY, _gravZ;
    private double _rotAlpha, _rotBeta, _rotGamma;

    // 3D Angles
    private double _tiltX = 20; // Default isometric angle
    private double _tiltY = -20;
    private double _tiltZ = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("motion") && caps["motion"];
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task RequestMotionPermissionAsync()
    {
        try
        {
            _motionModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/motion.module.js");
            var granted = await _motionModule.InvokeAsync<bool>("requestPermission");
            if (granted)
            {
                _gate?.ForceStatus("granted");
                await ToggleSensorListening();
            }
            else
            {
                _gate?.ForceStatus("denied");
                ToastService.Error("Motion sensor permission denied.");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Failed to request motion sensor permission: " + ex.Message);
        }
    }

    private async Task ToggleSensorListening()
    {
        _motionModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/motion.module.js");

        if (_isListening)
        {
            await _motionModule.InvokeVoidAsync("stopListening");
            _isListening = false;
            ToastService.Info("Sensors stopped.");
        }
        else
        {
            try
            {
                _selfReference = DotNetObjectReference.Create(this);
                await _motionModule.InvokeVoidAsync("startListening", _selfReference, nameof(UpdateMotionDataCallback));
                _isListening = true;
                _gate?.ForceStatus("granted");
                ToastService.Success("Listening to device motion...");
            }
            catch (Exception ex)
            {
                ToastService.Error("Failed to start motion sensors: " + ex.Message);
            }
        }
        StateHasChanged();
    }

    [JSInvokable]
    public void UpdateMotionDataCallback(MotionData data)
    {
        _accelX = data.AccelerationX;
        _accelY = data.AccelerationY;
        _accelZ = data.AccelerationZ;
        _gravX = data.AccelerationIncludingGravityX;
        _gravY = data.AccelerationIncludingGravityY;
        _gravZ = data.AccelerationIncludingGravityZ;
        _rotAlpha = data.RotationRateAlpha;
        _rotBeta = data.RotationRateBeta;
        _rotGamma = data.RotationRateGamma;

        // Convert gravity acceleration components to rotation angles (tilt)
        // 9.8 m/s^2 corresponds to approximately 90 degrees of tilt.
        // Clamp bounds to prevent excessive spinning.
        _tiltY = Math.Clamp(-data.AccelerationIncludingGravityX * 9, -90, 90);
        _tiltX = Math.Clamp(data.AccelerationIncludingGravityY * 9, -90, 90);
        
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_isListening && _motionModule != null)
        {
            try
            {
                await _motionModule.InvokeVoidAsync("stopListening");
            }
            catch
            {
                // Ignore dispose errors
            }
        }
        _selfReference?.Dispose();
        if (_motionModule != null)
        {
            await _motionModule.DisposeAsync();
        }
    }
}
