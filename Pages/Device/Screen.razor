@page "/device/screen"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Screen & Wake Lock - GlassWASM</PageTitle>

<PageHeader Title="Screen & Wake Lock" 
            Description="Control document fullscreen states, lock orientation modes, and activate Wake Locks to prevent screen dimming." 
            ApiSupported="_isSupported" />

<div class="page-container">
    <div class="screen-grid">
        <!-- Fullscreen Card -->
        <DemoCard Title="Fullscreen Manager">
            <p class="section-desc">Toggle the browser display between standard viewport and native fullscreen layout shell.</p>
            <div class="card-controls">
                @if (!_isFullscreen)
                {
                    <button class="btn-primary" @onclick="EnterFullscreenAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
                        Enter Fullscreen
                    </button>
                }
                else
                {
                    <button class="btn-control btn-danger" @onclick="ExitFullscreenAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14h6v6m10-6h-6v6M4 10h6V4m10 6h-6V4"></path></svg>
                        Exit Fullscreen
                    </button>
                }
            </div>
        </DemoCard>

        <!-- Wake Lock Card -->
        <DemoCard Title="Screen Wake Lock">
            <p class="section-desc">Toggle Wake Lock to prevent your device from turning off or dimming its screen during inactive periods.</p>
            <div class="wake-lock-status">
                <span class="status-label">Wake Lock:</span>
                @if (_isWakeLocked)
                {
                    <span class="badge active animate-pulse">Active (Preventing Sleep)</span>
                }
                else
                {
                    <span class="badge inactive">Inactive (Standard Sleep Rules)</span>
                }
            </div>
            
            <div class="card-controls">
                @if (!_isWakeLocked)
                {
                    <button class="btn-primary" @onclick="EnableWakeLockAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                        Prevent Display Sleep
                    </button>
                }
                else
                {
                    <button class="btn-control btn-danger" @onclick="DisableWakeLockAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
                        Allow Display Sleep
                    </button>
                }
            </div>
        </DemoCard>

        <!-- Screen Orientation Lock Card -->
        <DemoCard Title="Orientation Locker">
            <p class="section-desc">Lock display to portrait or landscape orientations. (Note: Most mobile browsers require entering fullscreen first).</p>
            
            <div class="orientation-form">
                <div class="form-group">
                    <label for="orient-select">Target Orientation</label>
                    <select id="orient-select" class="form-select" @bind="_selectedOrientation">
                        <option value="any">Auto (Unbound)</option>
                        <option value="portrait">Lock Portrait</option>
                        <option value="landscape">Lock Landscape</option>
                    </select>
                </div>

                <div class="card-controls">
                    <button class="btn-control btn-success" @onclick="LockOrientationAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                        Apply Lock
                    </button>
                </div>
            </div>
        </DemoCard>
    </div>
</div>

@code {
    private bool _isSupported = true;
    private IJSObjectReference? _screenModule;

    private bool _isFullscreen = false;
    private bool _isWakeLocked = false;
    private string _selectedOrientation = "portrait";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("screen") && caps["screen"];
                
                // Track fullscreen states in the document
                _isFullscreen = await JSRuntime.InvokeAsync<bool>("eval", "!!document.fullscreenElement");
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task InitModuleAsync()
    {
        _screenModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/screen.module.js");
    }

    private async Task EnterFullscreenAsync()
    {
        await InitModuleAsync();
        if (_screenModule != null)
        {
            try
            {
                await _screenModule.InvokeVoidAsync("requestFullscreen");
                _isFullscreen = true;
                ToastService.Success("Entered Fullscreen.");
            }
            catch (Exception ex)
            {
                ToastService.Error("Failed to enter fullscreen: " + ex.Message);
            }
        }
    }

    private async Task ExitFullscreenAsync()
    {
        await InitModuleAsync();
        if (_screenModule != null)
        {
            try
            {
                await _screenModule.InvokeVoidAsync("exitFullscreen");
                _isFullscreen = false;
                ToastService.Info("Exited Fullscreen.");
            }
            catch (Exception ex)
            {
                ToastService.Error("Failed to exit fullscreen: " + ex.Message);
            }
        }
    }

    private async Task EnableWakeLockAsync()
    {
        await InitModuleAsync();
        if (_screenModule != null)
        {
            var success = await _screenModule.InvokeAsync<bool>("requestWakeLock");
            if (success)
            {
                _isWakeLocked = true;
                ToastService.Success("Screen Wake Lock enabled.");
            }
            else
            {
                ToastService.Error("Failed to request Wake Lock.");
            }
        }
    }

    private async Task DisableWakeLockAsync()
    {
        await InitModuleAsync();
        if (_screenModule != null)
        {
            await _screenModule.InvokeVoidAsync("releaseWakeLock");
            _isWakeLocked = false;
            ToastService.Info("Screen Wake Lock released.");
        }
    }

    private async Task LockOrientationAsync()
    {
        await InitModuleAsync();
        if (_screenModule != null)
        {
            var success = await _screenModule.InvokeAsync<bool>("lockOrientation", _selectedOrientation);
            if (success)
            {
                ToastService.Success($"Orientation locked to: {_selectedOrientation}");
            }
            else
            {
                ToastService.Warning("Orientation locking failed. Note that this feature is typically only supported on mobile devices in Fullscreen mode.");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_isWakeLocked && _screenModule != null)
        {
            try
            {
                await _screenModule.InvokeVoidAsync("releaseWakeLock");
            }
            catch
            {
                // Ignore dispose errors
            }
        }
        if (_screenModule != null)
        {
            await _screenModule.DisposeAsync();
        }
    }
}
