@page "/device/battery"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Battery Status - GlassWASM</PageTitle>

<PageHeader Title="Battery Status Indicator" 
            Description="Track battery levels, charger attachment states, and charging/discharging time estimates represented by a glowing vector gauge." 
            ApiSupported="true" /> @* Always accessible due to interactive simulation fallback *@

<div class="page-container">
    @if (!_isSupported)
    {
        <div class="unsupported-banner warning">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            <div>
                <strong>API Unsupported:</strong> Your browser does not support the Battery Status API. 
                We have enabled <strong>Simulator Mode</strong> below so you can test the UI animations manually.
            </div>
        </div>
    }

    <div class="battery-layout">
        <!-- Left Side: Interactive SVG Gauge -->
        <DemoCard Title="Vector Gauge Display">
            <div class="gauge-display-container">
                <div class="battery-visual">
                    <svg class="battery-svg" viewBox="0 0 200 100">
                        <defs>
                            <!-- Glow filter -->
                            <filter id="battery-glow" x="-20%" y="-20%" width="140%" height="140%">
                                <feGaussianBlur stdDeviation="6" result="blur" />
                                <feComposite in="SourceGraphic" in2="blur" operator="over" />
                            </filter>
                        </defs>
                        <!-- Outer Shell -->
                        <rect x="12" y="16" width="156" height="68" rx="10" ry="10" fill="none" stroke="var(--text)" stroke-width="6" />
                        <!-- Tip -->
                        <path d="M 172 38 L 172 62 A 4 4 0 0 0 176 58 L 176 42 A 4 4 0 0 0 172 38 Z" fill="var(--text)" />
                        <!-- Level Bar with dynamic colors and SVG glow filter -->
                        @if (_level > 0.01)
                        {
                            <rect x="22" y="24" width="@LevelWidth" height="52" rx="6" ry="6" fill="@FillColor" filter="url(#battery-glow)" />
                        }
                        
                        <!-- Lightning Bolt -->
                        @if (_charging)
                        {
                            <g class="lightning-bolt" transform="translate(68, 18)">
                                <polygon points="25,4 40,28 26,28 32,58 14,30 26,30" fill="var(--bg)" stroke="var(--text)" stroke-width="3" stroke-linejoin="round" />
                                <polygon points="25,4 40,28 26,28 32,58 14,30 26,30" fill="var(--safety)" />
                            </g>
                        }
                    </svg>
                </div>

                <div class="level-percent">
                    @Percentage%
                </div>
                
                <div class="charging-label">
                    @if (_charging)
                    {
                        <span class="badge charging animate-pulse">Charging</span>
                    }
                    else
                    {
                        <span class="badge discharging">Discharging</span>
                    }
                </div>
            </div>
        </DemoCard>

        <!-- Right Side: Details & Simulator -->
        <div class="battery-sidebar">
            <DemoCard Title="Status & Estimations">
                <div class="stats-panel">
                    <div class="stat-item">
                        <span class="stat-label">Current Charge</span>
                        <span class="stat-value">@Percentage%</span>
                    </div>
                    
                    <div class="stat-item">
                        <span class="stat-label">Power Source</span>
                        <span class="stat-value">@(_charging ? "AC / USB Charger" : "Battery Power")</span>
                    </div>

                    @if (_charging)
                    {
                        <div class="stat-item">
                            <span class="stat-label">Time to Full Charge</span>
                            <span class="stat-value">@FormatTime(_chargingTime)</span>
                        </div>
                    }
                    else
                    {
                        <div class="stat-item">
                            <span class="stat-label">Time to Discharge</span>
                            <span class="stat-value">@FormatTime(_dischargingTime)</span>
                        </div>
                    }
                </div>
            </DemoCard>

            @if (!_isSupported)
            {
                <DemoCard Title="Simulator Controls">
                    <div class="simulator-controls">
                        <div class="form-group">
                            <label>Mock Charge Level: @Percentage%</label>
                            <input type="range" min="0" max="100" @bind-value="_mockLevel" @bind-value:event="oninput" @bind-value:after="UpdateMockValues" />
                        </div>

                        <div class="checkbox-group">
                            <label class="checkbox-container">
                                <input type="checkbox" @bind="_mockCharging" @bind:after="UpdateMockValues" />
                                <span class="checkmark"></span>
                                Simulated Charger Connected
                            </label>
                        </div>
                    </div>
                </DemoCard>
            }
        </div>
    </div>
</div>

@code {
    public class BatteryStatus
    {
        public double Level { get; set; }
        public bool Charging { get; set; }
        public double ChargingTime { get; set; }
        public double DischargingTime { get; set; }
    }

    private bool _isSupported = true;
    private IJSObjectReference? _batteryModule;
    private DotNetObjectReference<Battery>? _selfReference;

    // Battery values
    private double _level = 0.85;
    private bool _charging = false;
    private double _chargingTime = 0;
    private double _dischargingTime = 0;

    // Simulator mock values
    private int _mockLevel = 85;
    private bool _mockCharging = false;

    private int Percentage => (int)Math.Round(_level * 100);
    private double LevelWidth => Math.Max(0, 136 * _level);

    private string FillColor
    {
        get
        {
            if (_level <= 0.20) return "var(--danger)";
            if (_level <= 0.40) return "var(--safety)";
            return "#2ed573";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("battery") && caps["battery"];

                if (_isSupported)
                {
                    _batteryModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/battery.module.js");
                    var status = await _batteryModule.InvokeAsync<BatteryStatus>("getStatus");
                    if (status != null)
                    {
                        UpdateState(status);
                    }
                    _selfReference = DotNetObjectReference.Create(this);
                    await _batteryModule.InvokeVoidAsync("startListening", _selfReference, nameof(UpdateBatteryStatusCallback));
                }
                else
                {
                    // Default mockup values
                    UpdateMockValues();
                }
                StateHasChanged();
            }
            catch (Exception ex)
            {
                _isSupported = false;
                UpdateMockValues();
                Console.WriteLine("Battery load failed, defaulting to simulator: " + ex.Message);
                StateHasChanged();
            }
        }
    }

    private void UpdateState(BatteryStatus status)
    {
        _level = status.Level;
        _charging = status.Charging;
        _chargingTime = status.ChargingTime;
        _dischargingTime = status.DischargingTime;
    }

    [JSInvokable]
    public void UpdateBatteryStatusCallback(BatteryStatus status)
    {
        UpdateState(status);
        StateHasChanged();
    }

    private void UpdateMockValues()
    {
        _level = _mockLevel / 100.0;
        _charging = _mockCharging;
        _chargingTime = _charging ? 3600 : 0;
        _dischargingTime = _charging ? 0 : 14400;
        StateHasChanged();
    }

    private string FormatTime(double seconds)
    {
        if (double.IsInfinity(seconds) || seconds <= 0)
        {
            return "Unknown / Infinite";
        }
        var span = TimeSpan.FromSeconds(seconds);
        if (span.TotalHours >= 1)
        {
            return $"{(int)span.TotalHours}h {span.Minutes}m";
        }
        return $"{span.Minutes} minutes";
    }

    public async ValueTask DisposeAsync()
    {
        if (_isSupported && _batteryModule != null)
        {
            try
            {
                await _batteryModule.InvokeVoidAsync("stopListening");
            }
            catch
            {
                // Ignore dispose errors
            }
        }
        _selfReference?.Dispose();
        if (_batteryModule != null)
        {
            await _batteryModule.DisposeAsync();
        }
    }
}
