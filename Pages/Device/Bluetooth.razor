@page "/device/bluetooth"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService

<PageTitle>Bluetooth & NFC - GlassWASM</PageTitle>

<PageHeader Title="Bluetooth & NFC Scanner" 
            Description="Interact with nearby wireless devices. Perform Web Bluetooth BLE peripheral scans and scan passive NFC smart tags." 
            ApiSupported="_isBleSupported || _isNfcSupported" />

<div class="page-container">
    <div class="wireless-grid">
        <!-- Bluetooth Section -->
        <DemoCard Title="Web Bluetooth BLE Scanner">
            <div class="status-header">
                <span class="status-label">API Status:</span>
                @if (_isBleSupported)
                {
                    <span class="badge active">Supported</span>
                }
                else
                {
                    <span class="badge inactive">Simulator Mode Active</span>
                }
            </div>

            <p class="section-desc">Scan and list surrounding Bluetooth Low Energy (BLE) peripherals in your immediate vicinity.</p>

            <div class="scan-actions">
                @if (!_isBleScanning)
                {
                    <button class="btn-primary" @onclick="StartBluetoothScanAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5l11 11L12 23V1l5.5 5.5-11 11"></path></svg>
                        Scan BLE Peripherals
                    </button>
                }
                else
                {
                    <div class="scanning-indicator">
                        <div class="spinner"></div>
                        <span>Scanning for hardware nodes...</span>
                    </div>
                }
            </div>

            <div class="device-list">
                @if (_bleDevices.Count == 0 && !_isBleScanning)
                {
                    <div class="no-devices">
                        <p>No Bluetooth devices found.</p>
                    </div>
                }
                @foreach (var device in _bleDevices)
                {
                    <div class="device-item animate-slide-in">
                        <span class="device-icon">🌐</span>
                        <div class="device-info">
                            <span class="device-name">@device.Name</span>
                            <span class="device-id">ID: @device.Id</span>
                        </div>
                        <span class="device-rssi">@device.Rssi dBm</span>
                    </div>
                }
            </div>
        </DemoCard>

        <!-- NFC Section -->
        <DemoCard Title="WebNFC Smart Tag Reader">
            <div class="status-header">
                <span class="status-label">API Status:</span>
                @if (_isNfcSupported)
                {
                    <span class="badge active">Supported</span>
                }
                else
                {
                    <span class="badge inactive">Simulator Mode Active</span>
                }
            </div>

            <p class="section-desc">Hover your device over passive RFID/NFC smart stickers to read serialized payload texts.</p>

            <div class="scan-actions">
                @if (!_isNfcScanning)
                {
                    <button class="btn-control btn-success" @onclick="StartNfcScanAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
                        Listen for NFC Tags
                    </button>
                }
                else
                {
                    <div class="scanning-indicator">
                        <div class="pulse-beacon"></div>
                        <span>Align device near NFC tag...</span>
                    </div>
                }
            </div>

            @if (_nfcPayload != null)
            {
                <div class="nfc-card-result animate-scale-up">
                    <div class="nfc-header">
                        <span class="nfc-icon">🎴</span>
                        <span class="nfc-tag-type">RFID / NFC Tag Detected</span>
                    </div>
                    <div class="nfc-details">
                        <div class="nfc-row">
                            <span class="lbl">Serial ID:</span>
                            <span class="val monospace">@_nfcPayload.SerialId</span>
                        </div>
                        <div class="nfc-row">
                            <span class="lbl">Record Type:</span>
                            <span class="val">@_nfcPayload.RecordType</span>
                        </div>
                        <div class="nfc-row">
                            <span class="lbl">Payload Text:</span>
                            <span class="val highlight">@_nfcPayload.Message</span>
                        </div>
                    </div>
                </div>
            }
            else if (_isNfcScanning)
            {
                <div class="nfc-placeholder">
                    <p>Place tag on the back of your smartphone.</p>
                </div>
            }
        </DemoCard>
    </div>
</div>

@code {
    public class BleDeviceMock
    {
        public string Name { get; set; } = "";
        public string Id { get; set; } = "";
        public int Rssi { get; set; }
    }

    public class NfcTagMock
    {
        public string SerialId { get; set; } = "";
        public string RecordType { get; set; } = "";
        public string Message { get; set; } = "";
    }

    private bool _isBleSupported = false;
    private bool _isNfcSupported = false;

    // Scan statuses
    private bool _isBleScanning = false;
    private bool _isNfcScanning = false;

    // Data lists
    private readonly List<BleDeviceMock> _bleDevices = new();
    private NfcTagMock? _nfcPayload;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isBleSupported = caps.ContainsKey("bluetooth") && caps["bluetooth"];
                // Double check NDEFReader explicitly
                _isNfcSupported = await JSRuntime.InvokeAsync<bool>("eval", "'NDEFReader' in window");
                StateHasChanged();
            }
            catch
            {
                _isBleSupported = false;
                _isNfcSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task StartBluetoothScanAsync()
    {
        _isBleScanning = true;
        _bleDevices.Clear();
        StateHasChanged();

        if (_isBleSupported)
        {
            // Real Web Bluetooth Call
            try
            {
                // Note: Navigator.bluetooth.requestDevice displays browser-native prompt.
                // It is a security restriction that Blazor can invoke, but requires user gesture.
                var deviceInfo = await JSRuntime.InvokeAsync<Dictionary<string, string>>("eval", 
                    "navigator.bluetooth.requestDevice({ acceptAllDevices: true }).then(d => ({ name: d.name || 'Unknown BLE', id: d.id }))");
                
                if (deviceInfo != null && deviceInfo.ContainsKey("name"))
                {
                    _bleDevices.Add(new BleDeviceMock
                    {
                        Name = deviceInfo["name"],
                        Id = deviceInfo["id"],
                        Rssi = -55
                    });
                    ToastService.Success("Bluetooth device matched successfully.");
                }
            }
            catch (Exception ex)
            {
                ToastService.Warning("Bluetooth request canceled or failed: " + ex.Message);
            }
            _isBleScanning = false;
        }
        else
        {
            // Simulator Mode (BLE scans are mocked after a short delayed sweep)
            await Task.Delay(1800);
            
            _bleDevices.Add(new BleDeviceMock { Name = "Sony WH-1000XM4 (Audio)", Id = "8F:3A:C4:01:A0:98", Rssi = -42 });
            _bleDevices.Add(new BleDeviceMock { Name = "Apple Watch Series 9 (Wearable)", Id = "04:D2:7A:B4:EF:21", Rssi = -68 });
            _bleDevices.Add(new BleDeviceMock { Name = "Tile Tracker (Beacon)", Id = "CE:A1:33:55:FF:0B", Rssi = -85 });

            _isBleScanning = false;
            ToastService.Success("Bluetooth scan completed in simulator mode.");
        }
        StateHasChanged();
    }

    private async Task StartNfcScanAsync()
    {
        _isNfcScanning = true;
        _nfcPayload = null;
        StateHasChanged();

        if (_isNfcSupported)
        {
            // Real WebNFC Call
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", @"
                    const ndef = new NDEFReader();
                    ndef.scan().then(() => {
                        console.log('NFC Scan started');
                    });
                ");
                ToastService.Info("NFC scan active. Align tag.");
            }
            catch (Exception ex)
            {
                ToastService.Error("NFC scan initiation failed: " + ex.Message);
                _isNfcScanning = false;
            }
        }
        else
        {
            // Simulator Mode (Simulates scanning tag and finding one in 2.5s)
            await Task.Delay(2500);

            _nfcPayload = new NfcTagMock
            {
                SerialId = "04:6F:A2:81:B0:2C:90",
                RecordType = "Text / URI Record",
                Message = "https://glasswasm.pwa.template/keycard-102"
            };

            _isNfcScanning = false;
            ToastService.Success("NFC tag identified in simulator mode!");
        }
        StateHasChanged();
    }
}
