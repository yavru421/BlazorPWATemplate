@page "/device/geo"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Geolocation API - GlassWASM</PageTitle>

<PageHeader Title="Geolocation & Maps" 
            Description="Get current coordinates and track real-time position shifts, plotted on an interactive OpenStreetMap widget via Leaflet JS." 
            ApiSupported="_isSupported" />

<div class="page-container">
    <PermissionGate @ref="_gate" 
                    IsSupported="_isSupported" 
                    PermissionName="geolocation" 
                    PermissionLabel="Geolocation"
                    Description="This page requires access to your device's location to display coordinates and render your position on the map."
                    RequestPermission="GetPositionOnceAsync">
        
        <div class="geo-layout">
            <!-- Left Panel: Stats and Controls -->
            <div class="geo-sidebar">
                <DemoCard Title="Location Details">
                    @if (_coords != null)
                    {
                        <div class="stats-panel">
                            <div class="stat-item">
                                <span class="stat-label">Latitude</span>
                                <span class="stat-value">@_coords.Latitude.ToString("F6")°</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Longitude</span>
                                <span class="stat-value">@_coords.Longitude.ToString("F6")°</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Accuracy Buffer</span>
                                <span class="stat-value">@_coords.Accuracy.ToString("F1") meters</span>
                            </div>
                            @if (_lastUpdated.HasValue)
                            {
                                <div class="stat-item">
                                    <span class="stat-label">Last Updated</span>
                                    <span class="stat-value small">@_lastUpdated.Value.ToLocalTime().ToString("T")</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="no-coords">
                            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 10h22M1 14h22M3 18h18M3 6h18"/></svg>
                            <p>No location data retrieved yet</p>
                        </div>
                    }

                    <div class="geo-actions">
                        <button class="btn-primary" @onclick="GetPositionOnceAsync">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="22" y1="12" x2="18" y2="12"></line><line x1="6" y1="12" x2="2" y2="12"></line><line x1="12" y1="6" x2="12" y2="2"></line><line x1="12" y1="22" x2="12" y2="18"></line></svg>
                            Get Current Position
                        </button>

                        <button class="btn-control @(_isTracking ? "btn-danger" : "btn-success")" @onclick="ToggleTrackingAsync">
                            @if (_isTracking)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
                                <span>Stop Tracking</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                <span>Watch Coordinates</span>
                            }
                        </button>
                    </div>
                </DemoCard>
            </div>

            <!-- Right Panel: OpenStreetMap Leaflet Container -->
            <div class="geo-main">
                <DemoCard Title="Interactive Map Widget">
                    <div id="map-container" class="map-view">
                        @if (_coords == null && !_mapLoading)
                        {
                            <div class="map-placeholder">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                <p>Map will render here once location is fetched.</p>
                            </div>
                        }
                        @if (_mapLoading)
                        {
                            <div class="map-placeholder">
                                <div class="spinner"></div>
                                <p>Loading Leaflet resources and tiles...</p>
                            </div>
                        }
                    </div>
                </DemoCard>
            </div>
        </div>
    </PermissionGate>
</div>

@code {
    public class GeolocationCoords
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double Accuracy { get; set; }
    }

    private PermissionGate? _gate;
    private bool _isSupported = true;
    private bool _isTracking = false;
    private int? _watchId;
    private bool _mapLoading = false;
    private GeolocationCoords? _coords;
    private DateTime? _lastUpdated;
    private IJSObjectReference? _geoModule;
    private DotNetObjectReference<Geo>? _selfReference;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("geo") && caps["geo"];
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task GetPositionOnceAsync()
    {
        _mapLoading = true;
        StateHasChanged();

        try
        {
            _geoModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/geo.module.js");
            _coords = await _geoModule.InvokeAsync<GeolocationCoords>("getCurrentPosition");
            _lastUpdated = DateTime.UtcNow;
            _gate?.ForceStatus("granted");

            ToastService.Success("Position updated.");
            
            // Draw Map
            await _geoModule.InvokeVoidAsync("loadLeaflet");
            await _geoModule.InvokeVoidAsync("initMap", "map-container", _coords.Latitude, _coords.Longitude);
        }
        catch (Exception ex)
        {
            ToastService.Error("Could not retrieve location: " + ex.Message);
            _gate?.ForceStatus("denied");
        }
        finally
        {
            _mapLoading = false;
            StateHasChanged();
        }
    }

    private async Task ToggleTrackingAsync()
    {
        _geoModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/geo.module.js");

        if (_isTracking)
        {
            if (_watchId.HasValue)
            {
                await _geoModule.InvokeVoidAsync("clearWatch", _watchId.Value);
                _watchId = null;
            }
            _isTracking = false;
            ToastService.Info("Real-time coordinate watching stopped.");
        }
        else
        {
            try
            {
                _selfReference = DotNetObjectReference.Create(this);
                _watchId = await _geoModule.InvokeAsync<int>("watchPosition", _selfReference, nameof(UpdateLocationCallback));
                _isTracking = true;
                _gate?.ForceStatus("granted");
                ToastService.Success("Location tracking active.");
            }
            catch (Exception ex)
            {
                ToastService.Error("Failed to initiate tracking: " + ex.Message);
            }
        }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task UpdateLocationCallback(GeolocationCoords coords)
    {
        _coords = coords;
        _lastUpdated = DateTime.UtcNow;
        StateHasChanged();

        if (_geoModule != null)
        {
            try
            {
                // Smoothly center the Leaflet map widget on the newly watched coordinate set
                await _geoModule.InvokeVoidAsync("initMap", "map-container", coords.Latitude, coords.Longitude);
            }
            catch (Exception ex)
            {
                Console.WriteLine("Map tracking center failed: " + ex.Message);
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_watchId.HasValue && _geoModule != null)
        {
            try
            {
                await _geoModule.InvokeVoidAsync("clearWatch", _watchId.Value);
            }
            catch
            {
                // Ignore dispose errors
            }
        }
        _selfReference?.Dispose();
        if (_geoModule != null)
        {
            await _geoModule.DisposeAsync();
        }
    }
}
