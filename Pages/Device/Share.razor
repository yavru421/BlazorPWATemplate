@page "/device/share"
@inject IJSRuntime JSRuntime
@inject ClipboardService Clipboard
@inject NavigationManager Navigation
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Web Share & Clipboard - GlassWASM</PageTitle>

<PageHeader Title="Share & Clipboard" 
            Description="Share content instantly using native system dialogue sheets, and read or write data securely to the client clipboard." 
            ApiSupported="_isSupported" />

<div class="page-container">
    <div class="share-grid">
        <!-- Web Share Card -->
        <DemoCard Title="Native Web Share">
            <p class="section-desc">Test sharing links, titles, and text snippets to other apps installed on your device.</p>
            
            <div class="share-form">
                <div class="form-group">
                    <label for="share-title">Title</label>
                    <input id="share-title" type="text" class="form-input" @bind="_shareTitle" placeholder="Share title..." />
                </div>

                <div class="form-group">
                    <label for="share-text">Message Content</label>
                    <textarea id="share-text" class="form-input" rows="3" @bind="_shareText" placeholder="Share text description..."></textarea>
                </div>

                <div class="form-group">
                    <label for="share-url">Link URL</label>
                    <input id="share-url" type="text" class="form-input" @bind="_shareUrl" placeholder="https://..." />
                </div>

                <div class="form-actions">
                    <button class="btn-primary" @onclick="ShareContentAsync" disabled="@(!_isSupported)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                        Trigger Share Panel
                    </button>
                </div>
            </div>
        </DemoCard>

        <!-- Clipboard Card -->
        <DemoCard Title="Clipboard Security Manager">
            <p class="section-desc">Copy input text buffers to your computer's clipboard, or read strings directly out of it.</p>
            
            <div class="clipboard-form">
                <div class="form-group">
                    <label for="clipboard-input">Write Buffer</label>
                    <textarea id="clipboard-input" class="form-input" rows="3" @bind="_copyText" placeholder="Type text here to copy..."></textarea>
                </div>

                <div class="form-actions gap-12">
                    <button class="btn-control btn-success" @onclick="CopyToClipboardAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                        Copy Buffer
                    </button>
                    
                    <button class="btn-control" @onclick="PasteFromClipboardAsync">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                        Paste Buffer
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(_pastedText))
                {
                    <div class="pasted-content">
                        <span class="pasted-header">Pasted Output:</span>
                        <p class="pasted-body">@_pastedText</p>
                    </div>
                }
            </div>
        </DemoCard>
    </div>
</div>

@code {
    private bool _isSupported = true;
    private IJSObjectReference? _shareModule;

    // Form inputs
    private string _shareTitle = "GlassWASM UI Template";
    private string _shareText = "Reviewing the stunning Web API and glassmorphism interface on Blazor WASM.";
    private string _shareUrl = "";

    private string _copyText = "This text is loaded into the Blazor copy buffer! Try pasting it anywhere.";
    private string _pastedText = "";

    protected override async Task OnInitializedAsync()
    {
        _shareUrl = Navigation.BaseUri;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("share") && caps["share"];
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task ShareContentAsync()
    {
        _shareModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/share.module.js");
        var result = await _shareModule.InvokeAsync<bool>("share", _shareTitle, _shareText, _shareUrl);
        if (result)
        {
            ToastService.Success("Content shared successfully!");
        }
        else
        {
            ToastService.Warning("Share cancelled or failed.");
        }
    }

    private async Task CopyToClipboardAsync()
    {
        if (string.IsNullOrEmpty(_copyText))
        {
            ToastService.Warning("Buffer is empty.");
            return;
        }

        var result = await Clipboard.WriteTextAsync(_copyText);
        if (result)
        {
            ToastService.Success("Text copied to clipboard!");
        }
        else
        {
            ToastService.Error("Failed to write to clipboard.");
        }
    }

    private async Task PasteFromClipboardAsync()
    {
        var text = await Clipboard.ReadTextAsync();
        if (!string.IsNullOrEmpty(text))
        {
            _pastedText = text;
            ToastService.Success("Buffer read successfully.");
        }
        else
        {
            ToastService.Warning("Clipboard is empty or access denied.");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_shareModule != null)
        {
            await _shareModule.DisposeAsync();
        }
    }
}
