@page "/device/notify"
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Notifications API - GlassWASM</PageTitle>

<PageHeader Title="System Notifications" 
            Description="Request notification permission and push OS-level alert sheets, supporting instant delivery or delayed timer schedules." 
            ApiSupported="_isSupported" />

<div class="page-container">
    <PermissionGate @ref="_gate" 
                    IsSupported="_isSupported" 
                    PermissionName="notifications" 
                    PermissionLabel="Notifications"
                    Description="This page requires access to system notifications to display alerts in your OS tray."
                    RequestPermission="RequestPermissionAsync">
        
        <div class="notify-grid">
            <!-- Notification Customizer -->
            <DemoCard Title="Notification Composer">
                <div class="notify-form">
                    <div class="form-group">
                        <label for="notify-title">Alert Title</label>
                        <input id="notify-title" type="text" class="form-input" @bind="_title" placeholder="e.g. Alert Title" />
                    </div>

                    <div class="form-group">
                        <label for="notify-body">Message Body</label>
                        <textarea id="notify-body" class="form-input" rows="3" @bind="_body" placeholder="Type notification message..."></textarea>
                    </div>

                    <div class="notify-actions gap-12">
                        <button class="btn-primary" @onclick="TriggerNowAsync">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            Trigger Instantly
                        </button>

                        @if (!_isScheduled)
                        {
                            <button class="btn-control" @onclick="TriggerDelayedAsync">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                Delay 5 Seconds
                            </button>
                        }
                        else
                        {
                            <button class="btn-control btn-danger" @onclick="CancelDelayedAsync">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                Cancel Schedule (Timer active)
                            </button>
                        }
                    </div>
                </div>
            </DemoCard>

            <!-- Permission Status Card -->
            <DemoCard Title="Integration Status">
                <div class="status-panel">
                    <div class="status-row">
                        <span class="status-label">Browser Permission State</span>
                        <span class="status-badge-val @_permissionState.ToLower()">@_permissionState</span>
                    </div>

                    <div class="status-info">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                        <p>If permissions are blocked, reset them in your browser site settings bar to receive alerts.</p>
                    </div>
                </div>
            </DemoCard>
        </div>
    </PermissionGate>
</div>

@code {
    private PermissionGate? _gate;
    private bool _isSupported = true;
    private IJSObjectReference? _notifyModule;
    private string _permissionState = "Default";

    // Composer inputs
    private string _title = "GlassWASM Notification";
    private string _body = "This is a gorgeous notification triggered from your Blazor WASM PWA!";
    
    // Scheduled timer tracking
    private bool _isScheduled = false;
    private int? _scheduledTimeoutId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var capsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var caps = await capsModule.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                _isSupported = caps.ContainsKey("notify") && caps["notify"];
                
                if (_isSupported)
                {
                    // Fetch active permission string
                    _permissionState = await JSRuntime.InvokeAsync<string>("eval", "Notification.permission");
                    if (_permissionState == "granted")
                    {
                        _gate?.ForceStatus("granted");
                    }
                    else if (_permissionState == "denied")
                    {
                        _gate?.ForceStatus("denied");
                    }
                }
                StateHasChanged();
            }
            catch
            {
                _isSupported = false;
                StateHasChanged();
            }
        }
    }

    private async Task RequestPermissionAsync()
    {
        _notifyModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/notify.module.js");
        var result = await _notifyModule.InvokeAsync<string>("requestPermission");
        _permissionState = result;
        
        if (result == "granted")
        {
            _gate?.ForceStatus("granted");
            ToastService.Success("Notification permission granted!");
        }
        else
        {
            _gate?.ForceStatus("denied");
            ToastService.Warning("Notification permission: " + result);
        }
        StateHasChanged();
    }

    private async Task TriggerNowAsync()
    {
        _notifyModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/notify.module.js");
        
        var options = new
        {
            body = _body,
            icon = "icon-192.png", // PWA default icon
            badge = "icon-192.png",
            vibrate = new[] { 100, 50, 100 },
            tag = "glasswasm-alert",
            renotify = true
        };

        var result = await _notifyModule.InvokeAsync<bool>("showNotification", _title, options);
        if (result)
        {
            ToastService.Success("Notification triggered.");
        }
    }

    private async Task TriggerDelayedAsync()
    {
        _notifyModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/notify.module.js");
        
        var options = new
        {
            body = _body,
            icon = "icon-192.png",
            badge = "icon-192.png",
            vibrate = new[] { 100, 50, 100 },
            tag = "glasswasm-delayed",
            renotify = true
        };

        _scheduledTimeoutId = await _notifyModule.InvokeAsync<int>("scheduleLocal", _title, options, 5000);
        _isScheduled = true;
        ToastService.Info("Notification scheduled in 5 seconds. You can lock your device or switch tabs!");
        StateHasChanged();

        // Automatically clean up the schedule toggle status in Blazor after 5s
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            _isScheduled = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task CancelDelayedAsync()
    {
        if (_scheduledTimeoutId.HasValue && _notifyModule != null)
        {
            await _notifyModule.InvokeVoidAsync("cancelScheduledLocal", _scheduledTimeoutId.Value);
            _scheduledTimeoutId = null;
            _isScheduled = false;
            ToastService.Success("Scheduled notification cancelled.");
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_notifyModule != null)
        {
            await _notifyModule.DisposeAsync();
        }
    }
}
