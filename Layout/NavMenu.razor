@code {
    private Dictionary<string, bool> _caps = new()
    {
        { "camera", false },
        { "geo", false },
        { "motion", false },
        { "haptics", false },
        { "share", false },
        { "notify", false },
        { "battery", false },
        { "media", false },
        { "screen", false },
        { "bluetooth", false }
    };

    protected override void OnInitialized()
    {
        AppState.OnChange += HandleStateChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/capabilities.module.js");
                var results = await module.InvokeAsync<Dictionary<string, bool>>("checkCapabilities");
                if (results != null)
                {
                    foreach (var key in results.Keys)
                    {
                        _caps[key] = results[key];
                    }
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("Capability check failed: " + ex.Message);
            }
        }
    }

    private void HandleStateChange() => StateHasChanged();

    public void Dispose()
    {
        AppState.OnChange -= HandleStateChange;
    }
}
