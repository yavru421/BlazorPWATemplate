@inherits LayoutComponentBase
@inject AppStateContainer AppState
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@implements IDisposable

<div class="app-shell @ThemeClass @SidebarClass">
    <NavMenu />
    
    <main class="app-main">
        <header class="app-topbar">
            <button class="btn-toggle-sidebar" @onclick="ToggleSidebar" aria-label="Toggle Navigation Sidebar">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
            <div class="topbar-actions">
                <button class="btn-theme-toggle" @onclick="ToggleTheme" title="Toggle Light/Dark Theme" aria-label="Toggle Theme">
                    @if (AppState.Theme == AppTheme.Light)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                    }
                </button>
            </div>
        </header>

        <div class="app-content-wrapper">
            <div class="app-content">
                @Body
            </div>
        </div>
    </main>

    <ToastContainer />
</div>

@code {
    private string ThemeClass => AppState.Theme == AppTheme.Light ? "theme-light" : "theme-dark";
    private string SidebarClass => AppState.SidebarCollapsed ? "sidebar-collapsed" : "";

    protected override void OnInitialized()
    {
        AppState.OnChange += HandleStateChange;
        Navigation.LocationChanged += OnLocationChanged;
        AppState.SetLastVisitedRoute(Navigation.ToBaseRelativePath(Navigation.Uri));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Restore theme from localStorage
            try
            {
                var themeStr = await LocalStorage.GetItemAsync("theme");
                if (Enum.TryParse<AppTheme>(themeStr, out var savedTheme))
                {
                    AppState.SetTheme(savedTheme);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("Failed to restore theme settings: " + ex.Message);
            }

            // Restore sidebar status from localStorage
            try
            {
                var collapsedStr = await LocalStorage.GetItemAsync("sidebarCollapsed");
                if (bool.TryParse(collapsedStr, out var collapsed))
                {
                    AppState.SetSidebarCollapsed(collapsed);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("Failed to restore sidebar settings: " + ex.Message);
            }

            StateHasChanged();
        }
    }

    private void HandleStateChange() => StateHasChanged();

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        AppState.SetLastVisitedRoute(Navigation.ToBaseRelativePath(e.Location));
    }

    private async Task ToggleSidebar()
    {
        var nextValue = !AppState.SidebarCollapsed;
        AppState.SetSidebarCollapsed(nextValue);
        await LocalStorage.SetItemAsync("sidebarCollapsed", nextValue.ToString());
    }

    private async Task ToggleTheme()
    {
        var nextTheme = AppState.Theme == AppTheme.Dark ? AppTheme.Light : AppTheme.Dark;
        AppState.SetTheme(nextTheme);
        await LocalStorage.SetItemAsync("theme", nextTheme.ToString());
    }

    public void Dispose()
    {
        AppState.OnChange -= HandleStateChange;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
