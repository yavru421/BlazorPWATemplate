@inject IJSRuntime JSRuntime

@if (!IsSupported)
{
    <div class="permission-gate-card error-state">
        <div class="gate-icon alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        <h3>API Not Supported</h3>
        <p>The <strong>@PermissionLabel</strong> API is not supported in this browser. Please try a different modern browser.</p>
    </div>
}
else if (Status == "checking")
{
    <div class="permission-gate-card loading-state">
        <div class="spinner"></div>
        <p>Checking permission status...</p>
    </div>
}
else if (Status == "granted")
{
    @ChildContent
}
else if (Status == "denied")
{
    @if (DeniedContent != null)
    {
        @DeniedContent
    }
    else
    {
        <div class="permission-gate-card error-state">
            <div class="gate-icon locked">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            </div>
            <h3>Permission Denied</h3>
            <p>Access to <strong>@PermissionLabel</strong> was denied. Please reset the site permissions in your browser's address bar to use this feature.</p>
            <button class="btn-primary btn-retry" @onclick="CheckStatusAsync">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
                Retry Check
            </button>
        </div>
    }
}
else
{
    <div class="permission-gate-card prompt-state">
        <div class="gate-icon prompt">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 9.9-1"></path></svg>
        </div>
        <h3>Permission Required</h3>
        <p>@Description</p>
        <button class="btn-primary" @onclick="HandleRequestAsync">
            Grant Access
        </button>
    </div>
}

@code {
    [Parameter] public bool IsSupported { get; set; } = true;
    [Parameter] public string PermissionName { get; set; } = string.Empty;
    [Parameter] public string PermissionLabel { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = "This page requires device permissions to work.";
    [Parameter] public EventCallback RequestPermission { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; } = default!;
    [Parameter] public RenderFragment? DeniedContent { get; set; }

    public string Status { get; set; } = "checking";
    private IJSObjectReference? _module;

    protected override async Task OnInitializedAsync()
    {
        if (IsSupported)
        {
            await CheckStatusAsync();
        }
    }

    public async Task CheckStatusAsync()
    {
        if (!IsSupported) return;
        Status = "checking";
        StateHasChanged();

        try
        {
            _module ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/permissions.module.js");
            Status = await _module.InvokeAsync<string>("queryPermission", PermissionName);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine("Error checking permission status: " + ex.Message);
            Status = "prompt";
        }
        
        StateHasChanged();
    }

    private async Task HandleRequestAsync()
    {
        if (RequestPermission.HasDelegate)
        {
            await RequestPermission.InvokeAsync();
        }
        await CheckStatusAsync();
    }

    public void ForceStatus(string newStatus)
    {
        Status = newStatus;
        StateHasChanged();
    }
}
