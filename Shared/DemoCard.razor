@inject IClipboardService ClipboardService
@inject IToastService ToastService

<div class="demo-card">
    <div class="demo-header">
        <h3 class="demo-title">@Title</h3>
        @if (!string.IsNullOrEmpty(CodeSnippet))
        {
            <button class="btn-icon-sm @(_showCode ? "active" : "")" @onclick="ToggleCode" title="View Code">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
            </button>
        }
    </div>

    <div class="demo-body">
        @ChildContent
    </div>

    @if (!string.IsNullOrEmpty(CodeSnippet) && _showCode)
    {
        <div class="demo-code-wrapper">
            <div class="code-header">
                <span class="code-header-title">C# & Razor snippet</span>
                <button class="btn-copy-code" @onclick="CopySnippet">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    Copy
                </button>
            </div>
            <pre class="code-pre"><code>@CodeSnippet</code></pre>
        </div>
    }

    @if (Actions != null)
    {
        <div class="demo-actions">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Interactive Demo";
    [Parameter] public string? CodeSnippet { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; } = default!;
    [Parameter] public RenderFragment? Actions { get; set; }

    private bool _showCode = false;

    private void ToggleCode() => _showCode = !_showCode;

    private async Task CopySnippet()
    {
        if (string.IsNullOrEmpty(CodeSnippet)) return;
        var success = await ClipboardService.CopyTextAsync(CodeSnippet);
        if (success)
        {
            ToastService.Success("Code snippet copied to clipboard!");
        }
        else
        {
            ToastService.Error("Failed to copy code snippet.");
        }
    }
}
